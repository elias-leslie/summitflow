{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://summitflow.dev/schemas/plan.json",
  "title": "SummitFlow Plan Schema",
  "description": "Schema for plan.json - the canonical format for task planning. DB schema mirrors this exactly.",
  "type": "object",
  "required": ["title", "complexity"],

  "properties": {

    "_meta": {
      "type": "object",
      "description": "Schema metadata - not stored in DB, used for versioning/tracking",
      "properties": {
        "schema_version": { "type": "string", "const": "1.0.0" },
        "created_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" },
        "source": {
          "type": "string",
          "description": "How this plan was created",
          "enum": ["interview", "spec_import", "manual", "template"]
        }
      }
    },

    "title": {
      "type": "string",
      "minLength": 10,
      "maxLength": 200,
      "description": "Task title - concise, action-oriented"
    },

    "description": {
      "type": "string",
      "description": "Optional longer description with context"
    },

    "task_type": {
      "type": "string",
      "enum": ["feature", "bug", "task"],
      "default": "task"
    },

    "priority": {
      "type": "integer",
      "minimum": 0,
      "maximum": 4,
      "default": 2,
      "description": "0=critical, 1=high, 2=normal, 3=low, 4=backlog"
    },

    "labels": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Tags for filtering/grouping"
    },

    "complexity": {
      "type": "string",
      "enum": ["SIMPLE", "STANDARD", "COMPLEX"],
      "description": "Determines interview depth and checkpoints"
    },

    "done_when": {
      "type": "array",
      "description": "Simple checklist of conditions (strings) for task completion.",
      "items": { "type": "string" }
    },

    "autonomous": {
      "type": "boolean",
      "default": true,
      "description": "Whether this task should be executed autonomously"
    },

    "execution_contract": {
      "type": "object",
      "description": "Optional runtime-evaluation contract for frontend or hosted UX work.",
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["code_only", "runtime_eval", "runtime_eval_plus_design"]
        },
        "target_urls": {
          "type": "array",
          "items": { "type": "string" }
        },
        "user_flows": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "flow_id": { "type": "string" },
              "title": { "type": "string" },
              "target_url": { "type": "string" },
              "setup": {
                "type": "array",
                "items": { "type": "string" }
              },
              "actions": {
                "type": "array",
                "items": { "type": "string" }
              },
              "expected_outcomes": {
                "type": "array",
                "items": { "type": "string" }
              }
            },
            "additionalProperties": true
          }
        },
        "api_checks": {
          "type": "array",
          "items": { "type": "object", "additionalProperties": true }
        },
        "negative_cases": {
          "type": "array",
          "items": { "type": "object", "additionalProperties": true }
        },
        "evidence_requirements": {
          "type": "array",
          "items": { "type": "string" }
        },
        "design_criteria": {
          "type": "object",
          "additionalProperties": true
        },
        "risk_notes": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": true
    },

    "subtasks": {
      "type": "array",
      "description": "Work breakdown. Each subtask has steps. Optional for intent-only plans.",
      "items": {
        "type": "object",
        "required": ["id", "description"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[0-9]+\\.[0-9]+$",
            "description": "Subtask ID like 1.1, 2.3"
          },
          "phase": {
            "type": "string",
            "description": "Grouping label (backend, frontend, commands, verification)"
          },
          "subtask_type": {
            "type": "string",
            "description": "Agent routing type — determines which specialist agent executes this subtask",
            "enum": [
              "backend", "frontend", "ui-design", "refactor", "bug-fix",
              "test", "performance", "config", "devops",
              "database", "image-gen", "game-design", "design-review", "exploration"
            ]
          },
          "description": { "type": "string" },
          "steps": {
            "type": "array",
            "description": "Specific implementation actions.",
            "items": {
              "anyOf": [
                { "type": "string" },
                {
                  "type": "object",
                  "required": ["description"],
                  "properties": {
                    "description": { "type": "string" },
                    "spec": {
                      "type": "object",
                      "description": "Free-form implementation details stored in task_subtask_steps.spec"
                    }
                  },
                  "additionalProperties": false
                }
              ]
            }
          },
          "depends_on": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Subtask IDs that must complete first"
          }
        }
      }
    },

    "context": {
      "type": "object",
      "description": "Optional context for agent reference during execution",
      "additionalProperties": false,
      "properties": {
        "files_to_modify": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Existing files that will be modified"
        },
        "files_to_create": {
          "type": "array",
          "items": { "type": "string" },
          "description": "New files that will be created"
        },
        "risks": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Known risks or gotchas to watch for"
        },
        "references": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "title": { "type": "string" },
              "url": { "type": "string" }
            }
          },
          "description": "External docs, specs, examples"
        },
        "second_opinion": {
          "type": "object",
          "description": "Structured task-shape or pre-close critique metadata for high-risk work",
          "required": ["required", "stage", "status", "summary"],
          "properties": {
            "required": { "type": "boolean" },
            "stage": {
              "type": "string",
              "enum": ["task_shape", "pre_close", "both"]
            },
            "status": {
              "type": "string",
              "enum": ["pending", "completed", "waived", "needs_revision"]
            },
            "summary": { "type": "string" },
            "reviewed_by_agent": { "type": "string" },
            "reviewed_at": { "type": "string", "format": "date-time" },
            "verdict": { "type": "string" },
            "confidence": { "type": "string" },
            "findings": {
              "type": "array",
              "items": { "type": "string" }
            },
            "missing_requirements": {
              "type": "array",
              "items": { "type": "string" }
            },
            "edge_cases": {
              "type": "array",
              "items": { "type": "string" }
            },
            "test_gaps": {
              "type": "array",
              "items": { "type": "string" }
            },
            "rollout_gaps": {
              "type": "array",
              "items": { "type": "string" }
            },
            "simpler_alternative": { "type": "string" }
          },
          "additionalProperties": true
        },
        "testing_strategy": {
          "type": "string",
          "description": "How to test/verify the implementation"
        }
      }
    }
  },

  "allOf": [
    {
      "if": {
        "properties": { "complexity": { "enum": ["STANDARD", "COMPLEX"] } }
      },
      "then": {
        "required": ["done_when"],
        "properties": {
          "done_when": { "minItems": 1 }
        }
      }
    }
  ]
}
