{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://summitflow.dev/schemas/plan.json",
  "title": "SummitFlow Plan Schema",
  "description": "Schema for plan.json - the canonical format for task planning. DB schema mirrors this exactly.",
  "type": "object",
  "required": ["title", "objective", "complexity"],

  "properties": {

    "_meta": {
      "type": "object",
      "description": "Schema metadata - not stored in DB, used for versioning/tracking",
      "properties": {
        "schema_version": { "type": "string", "const": "1.0.0" },
        "created_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" },
        "source": {
          "type": "string",
          "description": "How this plan was created",
          "enum": ["interview", "spec_import", "manual", "template"]
        }
      }
    },

    "title": {
      "type": "string",
      "minLength": 10,
      "maxLength": 200,
      "description": "Task title - concise, action-oriented"
    },

    "description": {
      "type": "string",
      "description": "Optional longer description with context"
    },

    "task_type": {
      "type": "string",
      "enum": ["feature", "bug", "task"],
      "default": "task"
    },

    "priority": {
      "type": "integer",
      "minimum": 0,
      "maximum": 4,
      "default": 2,
      "description": "0=critical, 1=high, 2=normal, 3=low, 4=backlog"
    },

    "labels": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Tags for filtering/grouping"
    },

    "complexity": {
      "type": "string",
      "enum": ["SIMPLE", "STANDARD", "COMPLEX"],
      "description": "Determines interview depth and checkpoints"
    },

    "objective": {
      "type": "string",
      "minLength": 20,
      "description": "Spirit.why - THE ONE THING this task must achieve. Single sentence, measurable."
    },

    "spirit_anti": {
      "type": "string",
      "description": "What NOT to do. The failure mode to avoid. Required for STANDARD/COMPLEX."
    },

    "decisions": {
      "type": "array",
      "description": "Implementation choices made during planning. Agent must align with these.",
      "items": {
        "type": "object",
        "required": ["id", "title", "outcome"],
        "properties": {
          "id": { "type": "string", "pattern": "^d[0-9]+$" },
          "title": { "type": "string" },
          "options": {
            "type": "array",
            "items": { "type": "string" },
            "description": "What alternatives were considered"
          },
          "outcome": { "type": "string", "description": "What was decided" },
          "rationale": { "type": "string", "description": "Why this choice" }
        }
      }
    },

    "constraints": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Boundaries that must not be crossed"
    },

    "done_when": {
      "type": "array",
      "description": "Simple checklist of conditions (strings) for task completion.",
      "items": { "type": "string" }
    },

    "subtasks": {
      "type": "array",
      "description": "Work breakdown. Each subtask has steps. Optional for intent-only plans.",
      "items": {
        "type": "object",
        "required": ["id", "description", "steps"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[0-9]+\\.[0-9]+$",
            "description": "Subtask ID like 1.1, 2.3"
          },
          "phase": {
            "type": "string",
            "description": "Grouping label (backend, frontend, commands, verification)"
          },
          "description": { "type": "string" },
          "steps": {
            "type": "array",
            "minItems": 1,
            "description": "Specific actions. Each step must have a verify_command for the agent feedback loop.",
            "items": {
              "type": "object",
              "required": ["description", "verify_command"],
              "properties": {
                "description": { "type": "string" },
                "spec": {
                  "type": "object",
                  "description": "Free-form implementation details stored in task_subtask_steps.spec"
                },
                "verify_command": {
                  "type": "string",
                  "minLength": 1,
                  "description": "Self-verifying bash command. Exit code 0 = pass, non-zero = fail."
                }
              },
              "additionalProperties": false
            }
          },
          "depends_on": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Subtask IDs that must complete first"
          }
        }
      }
    },

    "context": {
      "type": "object",
      "description": "Optional context for agent reference during execution",
      "additionalProperties": false,
      "properties": {
        "files_to_modify": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Existing files that will be modified"
        },
        "files_to_create": {
          "type": "array",
          "items": { "type": "string" },
          "description": "New files that will be created"
        },
        "risks": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Known risks or gotchas to watch for"
        },
        "references": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "title": { "type": "string" },
              "url": { "type": "string" }
            }
          },
          "description": "External docs, specs, examples"
        },
        "testing_strategy": {
          "type": "string",
          "description": "How to test/verify the implementation"
        }
      }
    }
  },

  "allOf": [
    {
      "if": {
        "properties": { "complexity": { "enum": ["STANDARD", "COMPLEX"] } }
      },
      "then": {
        "required": ["spirit_anti", "done_when"],
        "properties": {
          "done_when": { "minItems": 1 }
        }
      }
    },
    {
      "if": {
        "properties": { "complexity": { "const": "COMPLEX" } }
      },
      "then": {
        "required": ["decisions"],
        "properties": {
          "decisions": { "minItems": 1 }
        }
      }
    }
  ]
}
