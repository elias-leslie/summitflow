# SummitFlow Ecosystem — Docker Environment Configuration
# Copy this file to .env and fill in your values.
#
# Required vars are uncommented. Optional vars are commented.
# Generate secrets: openssl rand -base64 32

# ─── Active Profile ──────────────────────────────────────────────
# Docker Compose reads this automatically — no --profile flag needed for restarts
# Options: summitflow | summitflow,agent-hub | full
# COMPOSE_PROFILES=full

# ─── Infrastructure ──────────────────────────────────────────────
# PostgreSQL superuser password (used by the postgres container)
POSTGRES_PASSWORD=changeme

# Per-project database passwords (used in init-db.sh and by app services)
SF_DB_PASSWORD=changeme
AH_DB_PASSWORD=changeme
PA_DB_PASSWORD=changeme

# Redis authentication password
REDIS_PASSWORD=changeme

# ─── Image Tags ─────────────────────────────────────────────────
# Docker image tag. Pin to an immutable release tag; do not use latest.
TAG=
# Hatchet image tag. Pin to an immutable release tag; do not use latest.
HATCHET_TAG=

# ─── Host Configuration ────────────────────────────────────────
# Absolute path to the user's home directory on the Docker host
# Used for volume mounts (backup scripts, host-home access)
HOST_HOME_PATH=/home/kasadis

# ─── Backup / SMB ──────────────────────────────────────────────
# SMB backup target host and share name
SMB_HOST=192.168.8.233
SMB_SHARE=summitflow-backups

# ─── SummitFlow ──────────────────────────────────────────────────
# CORS origins (comma-separated)
# CORS_ORIGINS=http://localhost:3001,http://localhost:3003

# Client credentials for Agent Hub access control
SUMMITFLOW_CLIENT_ID=
SUMMITFLOW_CLIENT_SECRET=
# SUMMITFLOW_REQUEST_SOURCE=summitflow

# ─── Agent Hub ───────────────────────────────────────────────────
# Agent Hub dashboard credentials (for AH frontend auth proxy)
AGENT_HUB_DASHBOARD_CLIENT_ID=
AGENT_HUB_DASHBOARD_CLIENT_SECRET=
# AGENT_HUB_DASHBOARD_REQUEST_SOURCE=agent-hub-dashboard

# Fernet encryption key: openssl rand -base64 32
AGENT_HUB_ENCRYPTION_KEY=
# Random secret key for JWT signing: openssl rand -base64 32
AGENT_HUB_SECRET_KEY=
# Shared secret for internal service-to-service auth: openssl rand -base64 32
INTERNAL_SERVICE_SECRET=

# ─── Hatchet ───────────────────────────────────────────────────
# Config auto-generated by hatchet-setup-config into docker/compose/hatchet-config/ on first run.
# Encryption keys, cookie secrets, and all server config persist in that directory.
# Token regeneration:
#   docker compose run --rm --no-deps hatchet-setup-config /hatchet/hatchet-admin token create --config /hatchet/config --tenant-id <UUID>
HATCHET_CLIENT_TOKEN=

# ─── Portfolio AI ────────────────────────────────────────────────
# Portfolio client credentials
PORTFOLIO_CLIENT_ID=
PORTFOLIO_CLIENT_SECRET=
# PORTFOLIO_REQUEST_SOURCE=portfolio-ai

# ─── Monkey Fight ────────────────────────────────────────────────
MONKEY_FIGHT_CLIENT_ID=
MONKEY_FIGHT_CLIENT_SECRET=
# MONKEY_FIGHT_REQUEST_SOURCE=monkey-fight
