# SummitFlow Ecosystem — Docker Environment Configuration
# Copy this file to .env and fill in your values.

# ─── Infrastructure ──────────────────────────────────────────────
# PostgreSQL superuser password (used by the postgres container)
POSTGRES_PASSWORD=changeme

# Per-project database passwords (used in init-db.sh and by app services)
SF_DB_PASSWORD=changeme
AH_DB_PASSWORD=changeme
PA_DB_PASSWORD=changeme

# ─── Image Tag ───────────────────────────────────────────────────
# Docker image tag (default: latest)
# TAG=latest
# TAG=v0.1.0

# ─── SummitFlow ──────────────────────────────────────────────────
# CORS origins (comma-separated)
# CORS_ORIGINS=http://localhost:3001,http://localhost:3003

# ─── Agent Hub ───────────────────────────────────────────────────
# AI provider API keys
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GOOGLE_API_KEY=...

# Client credentials for Agent Hub access control
# SUMMITFLOW_CLIENT_ID=
# SUMMITFLOW_CLIENT_SECRET=
# SUMMITFLOW_REQUEST_SOURCE=summitflow

# Agent Hub dashboard credentials (for AH frontend auth proxy)
# AGENT_HUB_DASHBOARD_CLIENT_ID=
# AGENT_HUB_DASHBOARD_CLIENT_SECRET=
# AGENT_HUB_DASHBOARD_REQUEST_SOURCE=agent-hub-dashboard

# ─── Portfolio AI ────────────────────────────────────────────────
# HuggingFace token for ML model downloads (optional)
# HF_TOKEN=hf_...

# Portfolio client credentials
# PORTFOLIO_CLIENT_ID=
# PORTFOLIO_CLIENT_SECRET=
# PORTFOLIO_REQUEST_SOURCE=portfolio-ai

# ─── Monkey Fight ────────────────────────────────────────────────
# MONKEY_FIGHT_CLIENT_ID=
# MONKEY_FIGHT_CLIENT_SECRET=
# MONKEY_FIGHT_REQUEST_SOURCE=monkey-fight

# ─── Hatchet ─────────────────────────────────────────────────────
# Hatchet client token (generate via: docker compose exec hatchet /hatchet-admin token create --config /config --tenant-id <UUID>)
# HATCHET_CLIENT_TOKEN=

# ─── Agent Hub Secrets ───────────────────────────────────────────
# Fernet encryption key (generate via: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
# AGENT_HUB_ENCRYPTION_KEY=
# Random secret key for JWT signing
# AGENT_HUB_SECRET_KEY=
# Shared secret for internal service-to-service auth
# INTERNAL_SERVICE_SECRET=
