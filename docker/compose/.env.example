# SummitFlow + Agent Hub Docker Compose environment.
# Copy to .env and replace placeholders before running docker compose.

# Active profile. Use summitflow, summitflow,agent-hub, or full.
COMPOSE_PROFILES=summitflow,agent-hub

# Infrastructure passwords. Replace all change-me values.
POSTGRES_PASSWORD=change-me-postgres
SF_DB_PASSWORD=change-me-summitflow
AH_DB_PASSWORD=change-me-agent-hub
PA_DB_PASSWORD=change-me-portfolio
REDIS_PASSWORD=change-me-redis

# Image tags. local is useful when using docker-compose.dev.yml to build from source.
TAG=local
HATCHET_TAG=v0.84.0
DOCKER_GID=990

# Host configuration. Set to the Docker host user's home directory.
HOST_HOME_PATH=/home/YOUR_USER

# Optional backup/SMB target.
SMB_HOST=
SMB_SHARE=

# SummitFlow -> Agent Hub client registration.
SUMMITFLOW_CLIENT_ID=summitflow
SUMMITFLOW_CLIENT_SECRET=
SUMMITFLOW_REQUEST_SOURCE=summitflow

# Agent Hub dashboard/client registration.
AGENT_HUB_DASHBOARD_CLIENT_ID=agent-hub-dashboard
AGENT_HUB_DASHBOARD_CLIENT_SECRET=
AGENT_HUB_DASHBOARD_REQUEST_SOURCE=agent-hub-dashboard

# Agent Hub secrets. Generate fresh values for each install.
AGENT_HUB_ENCRYPTION_KEY=
AGENT_HUB_SECRET_KEY=
INTERNAL_SERVICE_SECRET=

# Hatchet. Run docker/scripts/generate-hatchet-token.sh after infrastructure starts.
HATCHET_CLIENT_TOKEN=
HATCHET_TENANT_ID=

# Optional companion app client registrations.
PORTFOLIO_CLIENT_ID=portfolio-ai
PORTFOLIO_CLIENT_SECRET=
PORTFOLIO_REQUEST_SOURCE=portfolio-ai
MONKEY_FIGHT_CLIENT_ID=monkey-fight
MONKEY_FIGHT_CLIENT_SECRET=
MONKEY_FIGHT_REQUEST_SOURCE=monkey-fight

# Optional AI/provider keys for Agent Hub.
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
DEEPSEEK_API_KEY=
KIMI_CODE_API_KEY=
MOONSHOT_API_KEY=
MINIMAX_API_KEY=
XAI_API_KEY=
ZHIPU_API_KEY=
NVIDIA_API_KEY=
CLOUDFLARE_API_KEY=
CLOUDFLARE_ACCOUNT_ID=

# Optional health URLs used by SummitFlow smoke checks.
AGENT_HUB_HEALTH_URL=http://agent-hub-api:8003/health
PORTFOLIO_HEALTH_URL=
A_TERM_HEALTH_URL=
