#!/usr/bin/env bash
# sf-browser - SummitFlow remote browser automation wrapper.
#
# Default engine: Chrome (works for screenshots, console errors, and DOM).
# Use --lp to force Lightpanda for lightweight DOM-only work.
#
# Usage:
#   sf-browser health                           Check engine status
#   sf-browser open <url>                       Open URL (Chrome, 1600x900 viewport)
#   sf-browser screenshot [path]                Screenshot current page
#   sf-browser check <url> [screenshot-path]    Open + screenshot + console errors
#   sf-browser snapshot                         Accessibility tree
#   sf-browser eval <js>                        Run JavaScript
#   sf-browser [command] [args...]              Standardized browser interface
#
# Flags:
#   --lp        Force Lightpanda engine
#   --chrome    Force Chrome engine (default)

set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

HOST="${SF_BROWSER_HOST:-192.168.8.234}"
AGENT_BROWSER_BIN="${AGENT_BROWSER_BIN:-${HOME}/.local/bin/agent-browser}"
MANAGED_AGENT_BROWSER_BIN="${HOME}/.local/share/agent-browser-managed/node_modules/.bin/agent-browser"
LOCAL_WRAPPER_BIN="${SCRIPT_DIR}/agent-browser-wrapper.js"
AGENT_BROWSER_REAPER_BIN="${AGENT_BROWSER_REAPER_BIN:-${SCRIPT_DIR}/agent-browser-idle-reaper.js}"

print_help() {
    cat <<'EOF'
sf-browser - SummitFlow browser automation wrapper

Usage:
  sf-browser health
  sf-browser check [--session <name>] <url> [screenshot-path]
  sf-browser open <url>
  sf-browser screenshot [path]
  sf-browser snapshot
  sf-browser eval <js>
  sf-browser [--chrome|--lp|--engine <name>] <command> [args...]

Behavior:
  sf-browser is the canonical SummitFlow interface for browser UI verification.
  It standardizes remote CDP attachment, engine selection, default viewport,
  submit-button handling, and tab cleanup for all agents.
  It also prunes stale orphaned agent-browser helpers before each run.

Built-in commands:
  health      Report remote Chrome and Lightpanda engine health
  check       Open a URL, capture a screenshot, and report console/network issues
  update      Show the managed browser package version and upgrade instructions

Forwarded commands:
  All other commands are executed through the underlying browser engine with
  the active remote CDP session already attached. Common examples:
    sf-browser open http://127.0.0.1:3002
    sf-browser snapshot
    sf-browser click "#save"
    sf-browser eval "document.title"

Flags:
  --chrome    Force Chrome
  --lp        Force Lightpanda
  --engine    Explicit engine name (chrome or lightpanda)
  -h, --help  Show this help
EOF
}

maybe_print_help() {
    local args=("$@")

    if [[ $# -eq 0 ]]; then
        print_help
        exit 0
    fi

    local index=0
    while [[ $index -lt ${#args[@]} ]]; do
        local arg="${args[$index]}"
        case "$arg" in
            --chrome|--lp)
                ((index += 1))
                ;;
            --engine)
                ((index += 2))
                ;;
            -h|--help|help)
                print_help
                exit 0
                ;;
            *)
                break
                ;;
        esac
    done

    if [[ $index -ge ${#args[@]} ]]; then
        print_help
        exit 0
    fi
}

maybe_print_help "$@"

if [[ ! -x "${AGENT_BROWSER_BIN}" ]]; then
    if command -v agent-browser >/dev/null 2>&1; then
        AGENT_BROWSER_BIN="$(command -v agent-browser)"
    elif [[ -x "${LOCAL_WRAPPER_BIN}" ]]; then
        AGENT_BROWSER_BIN="${LOCAL_WRAPPER_BIN}"
    elif [[ -x "${MANAGED_AGENT_BROWSER_BIN}" ]]; then
        AGENT_BROWSER_BIN="${MANAGED_AGENT_BROWSER_BIN}"
    fi
fi

prune_agent_browser_helpers() {
    [[ "${SF_BROWSER_SKIP_PRUNE:-0}" != "1" ]] || return 0
    [[ -x "${AGENT_BROWSER_REAPER_BIN}" ]] || return 0
    node "${AGENT_BROWSER_REAPER_BIN}" >/dev/null 2>&1 || true
}

prune_agent_browser_helpers

cdp_ws() {
    local port="$1"
    local raw ws
    raw=$(curl -sf --connect-timeout 2 "http://${HOST}:${port}/json/version" 2>/dev/null) || return 1
    ws=$(echo "$raw" | jq -r '.webSocketDebuggerUrl // empty' 2>/dev/null) || return 1
    [[ -z "$ws" ]] && return 1
    normalize_ws_host "$ws" "$port"
}

engine_up() {
    curl -sf --connect-timeout 2 "http://${HOST}:$1/json/version" >/dev/null 2>&1
}

json_unwrap() {
    echo "${1:-}" | jq -r '. // .' 2>/dev/null || echo "${1:-}"
}

normalize_ws_host() {
    local ws="$1"
    local port="$2"
    echo "$ws" | sed "s|0\.0\.0\.0:[0-9]*|${HOST}:${port}|; s|127\.0\.0\.1:[0-9]*|${HOST}:${port}|"
}

create_target_ws() {
    local port="$1"
    local target_url="${2:-about:blank}"
    local raw target_id target_ws
    local encoded_url

    encoded_url=$(jq -rn --arg value "$target_url" '$value | @uri') || return 1

    raw=$(curl -sf -X PUT "http://${HOST}:${port}/json/new?${encoded_url}" 2>/dev/null) || return 1
    target_id=$(echo "$raw" | jq -r '.id // empty' 2>/dev/null) || return 1
    target_ws=$(echo "$raw" | jq -r '.webSocketDebuggerUrl // empty' 2>/dev/null) || return 1
    [[ -n "$target_id" && -n "$target_ws" ]] || return 1

    printf '%s\n%s\n' "$target_id" "$(normalize_ws_host "$target_ws" "$port")"
}

close_target_ws() {
    local port="$1"
    local target_id="$2"
    [[ -n "$target_id" ]] || return 0
    curl -sf "http://${HOST}:${port}/json/close/${target_id}" >/dev/null 2>&1 || true
}

close_all_tabs() {
    local port="$1"
    curl -sf "http://${HOST}:${port}/json/list" 2>/dev/null \
        | jq -r '.[].id' 2>/dev/null \
        | while read -r tab_id; do
            [[ -n "$tab_id" ]] || continue
            curl -sf "http://${HOST}:${port}/json/close/${tab_id}" >/dev/null 2>&1 || true
        done
}

generate_check_session_name() {
    printf 'sf-browser-check-%s-%s\n' "$$" "$(date +%s%N)"
}

close_current_tab() {
    "$AGENT_BROWSER_BIN" --cdp "$WS" "$@" tab close >/dev/null 2>&1 || true
}

extract_check_context_args() {
    local args=("$@")

    if [[ "${args[0]:-}" == "--session" ]]; then
        [[ -n "${args[1]:-}" ]] || {
            echo "ERROR: --session requires a name" >&2
            exit 1
        }
        printf '%s\n' "${args[0]}" "${args[1]}"
    fi
}

strip_check_context_args() {
    local args=("$@")

    if [[ "${args[0]:-}" == "--session" ]]; then
        printf '%s\n' "${args[@]:2}"
        return 0
    fi
    printf '%s\n' "${args[@]}"
}

default_check_context_args() {
    printf '%s\n' "--session" "$(generate_check_session_name)"
}

check_lock_path() {
    local base_dir
    if [[ -n "${XDG_RUNTIME_DIR:-}" ]]; then
        base_dir="${XDG_RUNTIME_DIR}/sf-browser"
    elif [[ -n "${HOME:-}" ]]; then
        base_dir="${HOME}/.cache/sf-browser"
    else
        base_dir="/tmp/sf-browser"
    fi

    mkdir -p "$base_dir"
    printf '%s\n' "${base_dir}/check.lock"
}

acquire_check_lock() {
    local lock_path
    lock_path="$(check_lock_path)"
    exec 9>"$lock_path"
    flock -w "${SF_BROWSER_CHECK_LOCK_WAIT:-120}" 9 || {
        echo "ERROR: Timed out waiting for sf-browser check lock" >&2
        exit 1
    }
}

selector_is_ref() {
    [[ "${1:-}" == @* ]]
}

selector_json() {
    jq -Rn --arg selector "${1:-}" '$selector'
}

selector_submit_probe_script() {
    local selector_json_value="$1"
    cat <<EOF
(() => {
  const selector = ${selector_json_value};
  const isXPath = selector.startsWith('//') || selector.startsWith('.//') || selector.startsWith('(');
  const resolve = () => {
    if (isXPath) {
      return document.evaluate(selector, document, null, XPathResult.FIRST_ORDERED_NODE_TYPE, null).singleNodeValue;
    }
    return document.querySelector(selector);
  };
  const element = resolve();
  if (!element) {
    return JSON.stringify({ found: false });
  }
  const tagName = (element.tagName || '').toLowerCase();
  const rawType = ((element.getAttribute && element.getAttribute('type')) || '').toLowerCase();
  const submitCapable =
    (tagName === 'button' && (rawType === '' || rawType === 'submit')) ||
    (tagName === 'input' && rawType === 'submit');
  const form = typeof element.closest === 'function' ? element.closest('form') : null;
  return JSON.stringify({
    found: true,
    disabled: Boolean(element.disabled),
    submitCapable: Boolean(submitCapable && form),
  });
})()
EOF
}

selector_request_submit_script() {
    local selector_json_value="$1"
    cat <<EOF
(() => {
  const selector = ${selector_json_value};
  const isXPath = selector.startsWith('//') || selector.startsWith('.//') || selector.startsWith('(');
  const resolve = () => {
    if (isXPath) {
      return document.evaluate(selector, document, null, XPathResult.FIRST_ORDERED_NODE_TYPE, null).singleNodeValue;
    }
    return document.querySelector(selector);
  };
  const element = resolve();
  if (!element) {
    throw new Error('Submit selector not found');
  }
  const form = typeof element.closest === 'function' ? element.closest('form') : null;
  if (!form) {
    throw new Error('Submit control is not inside a form');
  }
  form.requestSubmit(element);
  return 'submitted';
})()
EOF
}

selector_needs_submit_semantics() {
    local selector="$1"
    shift
    local raw probe

    selector_is_ref "$selector" && return 1

    raw=$("$AGENT_BROWSER_BIN" --cdp "$WS" "$@" eval "$(selector_submit_probe_script "$(selector_json "$selector")")" 2>/dev/null) || return 1
    probe=$(json_unwrap "$raw")
    [[ "$(echo "$probe" | jq -r '.submitCapable // false' 2>/dev/null)" == "true" ]] || return 1
    [[ "$(echo "$probe" | jq -r '.disabled // false' 2>/dev/null)" != "true" ]] || return 1
    return 0
}

submit_via_form() {
    local selector="$1"
    shift
    "$AGENT_BROWSER_BIN" --cdp "$WS" "$@" eval "$(selector_request_submit_script "$(selector_json "$selector")")" >/dev/null 2>&1
    "$AGENT_BROWSER_BIN" --cdp "$WS" "$@" wait "${SF_BROWSER_SUBMIT_WAIT:-1200}" >/dev/null 2>&1 || true
}

extract_command_and_target() {
    local args=("$@")
    local command=""
    local target=""
    local idx=0

    while [[ $idx -lt ${#args[@]} ]]; do
        local arg="${args[$idx]}"
        case "$arg" in
            --session|--headers|--device|--wait)
                ((idx += 2))
                continue
                ;;
            --json)
                ((idx += 1))
                continue
                ;;
            --*)
                ((idx += 1))
                continue
                ;;
        esac

        if [[ -z "$command" ]]; then
            command="$arg"
        elif [[ -z "$target" ]]; then
            target="$arg"
            break
        fi
        ((idx += 1))
    done

    printf '%s\n%s\n' "$command" "$target"
}

extract_eval_context_args() {
    local args=("$@")
    local idx=0

    while [[ $idx -lt ${#args[@]} ]]; do
        local arg="${args[$idx]}"
        case "$arg" in
            --session)
                if [[ $((idx + 1)) -lt ${#args[@]} ]]; then
                    printf '%s\n' "$arg" "${args[$((idx + 1))]}"
                fi
                ((idx += 2))
                continue
                ;;
            --json)
                ((idx += 1))
                continue
                ;;
            --*)
                if [[ "$arg" == "--headers" || "$arg" == "--device" || "$arg" == "--wait" ]]; then
                    ((idx += 2))
                else
                    ((idx += 1))
                fi
                continue
                ;;
            *)
                break
                ;;
        esac
    done
}

# --- Built-in commands ---

case "${1:-}" in
    health)
        printf "%-12s %-6s %-6s %s\n" "ENGINE" "PORT" "STATUS" "DETAILS"
        for endpoint in "chrome:9222" "lightpanda:9223"; do
            name="${endpoint%%:*}"
            port="${endpoint##*:}"
            if engine_up "$port"; then
                details=$(curl -sf "http://${HOST}:${port}/json/version" | jq -r '.Browser // .webSocketDebuggerUrl' 2>/dev/null)
                printf "%-12s %-6s %-6s %s\n" "$name" "$port" "UP" "$details"
            else
                printf "%-12s %-6s %-6s %s\n" "$name" "$port" "DOWN" "-"
            fi
        done
        exit 0
        ;;
    update)
        current=$("$AGENT_BROWSER_BIN" --version 2>/dev/null | grep -oP '[\d.]+' | head -1)
        latest=$(npm view agent-browser version 2>/dev/null || echo "?")
        echo "agent-browser: installed=${current} latest=${latest}"
        if [[ "$current" != "$latest" && "$latest" != "?" ]]; then
            echo "  UPDATE: bash ${SCRIPT_DIR}/setup-agent-browser.sh ${latest}"
        fi
        echo ""
        echo "Browser engines are managed on the test VM:"
        echo "  docker pull lightpanda/browser:nightly && docker restart lightpanda"
        echo "  docker compose -f docker/compose/docker-compose.yml --profile browser build agent-browser && docker compose -f docker/compose/docker-compose.yml --profile browser up -d agent-browser"
        exit 0
        ;;
    check)
        # High-level: open URL, wait, screenshot, collect console errors — one command.
        shift
        mapfile -t CHECK_CONTEXT < <(extract_check_context_args "$@")
        mapfile -t CHECK_ARGS < <(strip_check_context_args "$@")
        if [[ ${#CHECK_CONTEXT[@]} -eq 0 ]]; then
            mapfile -t CHECK_CONTEXT < <(default_check_context_args)
        fi

        URL="${CHECK_ARGS[0]:-}"
        [[ -n "$URL" ]] || {
            echo "Usage: sf-browser check [--session <name>] <url> [screenshot-path]" >&2
            exit 1
        }
        SCREENSHOT_PATH="${CHECK_ARGS[1]:-/tmp/sf-browser-check.png}"
        WAIT_MS="${SF_BROWSER_CHECK_WAIT:-5000}"

        # Direct CDP operations on the shared Chrome VM are not concurrency-safe.
        acquire_check_lock

        # Start from a clean browser tab set so direct CDP commands cannot drift
        # onto unrelated leftover tabs from earlier runs.
        close_all_tabs 9222

        # Always use Chrome for check and isolate each run to a dedicated page target.
        mapfile -t CHECK_TARGET < <(create_target_ws 9222 "$URL")
        CHECK_TARGET_ID="${CHECK_TARGET[0]:-}"
        CHECK_WS="${CHECK_TARGET[1]:-}"
        [[ -n "$CHECK_TARGET_ID" && -n "$CHECK_WS" ]] || {
            echo "ERROR: Unable to create an isolated Chrome tab on ${HOST}:9222" >&2
            exit 1
        }
        WS="$CHECK_WS"
        trap 'close_target_ws 9222 "${CHECK_TARGET_ID:-}"' EXIT

        # Set viewport
        "$AGENT_BROWSER_BIN" --cdp "$WS" "${CHECK_CONTEXT[@]}" set viewport 1600 900 2>/dev/null || true

        # Allow the page created for this target to settle before inspection.
        "$AGENT_BROWSER_BIN" --cdp "$WS" "${CHECK_CONTEXT[@]}" wait "$WAIT_MS" 2>/dev/null || true

        # Inject console error capture and wait for late errors
        "$AGENT_BROWSER_BIN" --cdp "$WS" "${CHECK_CONTEXT[@]}" eval "
            window.__sfErrors = []; window.__sfWarnings = [];
            const _oe = console.error; console.error = function(...a) { window.__sfErrors.push(a.map(String).join(' ')); _oe.apply(console,a); };
            const _ow = console.warn; console.warn = function(...a) { window.__sfWarnings.push(a.map(String).join(' ')); _ow.apply(console,a); };
            'capturing'
        " >/dev/null 2>&1 || true

        # Brief wait for late async errors
        "$AGENT_BROWSER_BIN" --cdp "$WS" "${CHECK_CONTEXT[@]}" wait 2000 2>/dev/null || true

        # Screenshot
        "$AGENT_BROWSER_BIN" --cdp "$WS" "${CHECK_CONTEXT[@]}" screenshot "$SCREENSHOT_PATH" 2>/dev/null

        # Collect errors (agent-browser wraps eval output in quotes, so we strip them)
        RAW_ERRORS=$("$AGENT_BROWSER_BIN" --cdp "$WS" "${CHECK_CONTEXT[@]}" eval "JSON.stringify({errors: window.__sfErrors || [], warnings: window.__sfWarnings || [], url: location.href, title: document.title})" 2>/dev/null) || RAW_ERRORS='{"errors":[],"warnings":[]}'
        ERRORS=$(echo "$RAW_ERRORS" | jq -r '. // .' 2>/dev/null) || ERRORS="$RAW_ERRORS"

        # Also check for failed network requests via performance API
        RAW_NETWORK=$("$AGENT_BROWSER_BIN" --cdp "$WS" "${CHECK_CONTEXT[@]}" eval "
            JSON.stringify(
                performance.getEntriesByType('resource')
                    .filter(e => e.responseStatus >= 400)
                    .map(e => e.responseStatus + ' ' + e.name.split('/').pop())
            )
        " 2>/dev/null) || RAW_NETWORK="[]"
        NETWORK_ERRORS=$(echo "$RAW_NETWORK" | jq -r '. // .' 2>/dev/null) || NETWORK_ERRORS="$RAW_NETWORK"

        # Output results
        echo "Screenshot: ${SCREENSHOT_PATH}"
        echo "Page: $(echo "$ERRORS" | jq -r '.url // "unknown"' 2>/dev/null)"
        echo "Title: $(echo "$ERRORS" | jq -r '.title // "unknown"' 2>/dev/null)"

        ERROR_COUNT=$(echo "$ERRORS" | jq -r '.errors | length' 2>/dev/null || echo 0)
        WARN_COUNT=$(echo "$ERRORS" | jq -r '.warnings | length' 2>/dev/null || echo 0)
        NETWORK_COUNT=$(echo "$NETWORK_ERRORS" | jq -r 'length' 2>/dev/null || echo 0)

        if [[ "$ERROR_COUNT" -gt 0 ]]; then
            echo ""
            echo "Console errors (${ERROR_COUNT}):"
            echo "$ERRORS" | jq -r '.errors[]' 2>/dev/null | head -20
        fi
        if [[ "$WARN_COUNT" -gt 0 ]]; then
            echo ""
            echo "Console warnings (${WARN_COUNT}):"
            echo "$ERRORS" | jq -r '.warnings[]' 2>/dev/null | head -10
        fi
        if [[ "$NETWORK_COUNT" -gt 0 ]]; then
            echo ""
            echo "Failed network requests (${NETWORK_COUNT}):"
            echo "$NETWORK_ERRORS" | jq -r '.[]' 2>/dev/null | head -20
        fi
        if [[ "$ERROR_COUNT" -eq 0 && "$WARN_COUNT" -eq 0 && "$NETWORK_COUNT" -eq 0 ]]; then
            echo "No console errors, warnings, or failed network requests."
        fi
        exit 0
        ;;
esac

# --- Engine selection ---

ENGINE="${SF_BROWSER_ENGINE:-}"
while [[ "${1:-}" == --* ]]; do
    case "$1" in
        --chrome)
            ENGINE=chrome
            shift
            ;;
        --lp)
            ENGINE=lightpanda
            shift
            ;;
        --engine)
            ENGINE="${2:-chrome}"
            shift 2
            ;;
        *)
            break
            ;;
    esac
done

# Default engine: Chrome first (agents need screenshots most often)
if [[ -z "$ENGINE" ]]; then
    if engine_up 9222; then
        ENGINE=chrome
    elif engine_up 9223; then
        ENGINE=lightpanda
    else
        echo "ERROR: No browsers available on ${HOST}" >&2
        exit 1
    fi
fi

# Resolve WebSocket URL
if [[ "$ENGINE" == "lightpanda" ]]; then
    WS=$(cdp_ws 9223 2>/dev/null) || WS=$(cdp_ws 9222 2>/dev/null) || {
        echo "ERROR: No browsers available on ${HOST}" >&2
        exit 1
    }
else
    WS=$(cdp_ws 9222 2>/dev/null) || WS=$(cdp_ws 9223 2>/dev/null) || {
        echo "ERROR: No browsers available on ${HOST}" >&2
        exit 1
    }
fi

# --- Viewport ---

DEFAULT_VIEWPORT_WIDTH="${SF_BROWSER_VIEWPORT_WIDTH:-1600}"
DEFAULT_VIEWPORT_HEIGHT="${SF_BROWSER_VIEWPORT_HEIGHT:-900}"

should_apply_default_viewport() {
    [[ "${SF_BROWSER_DISABLE_DEFAULT_VIEWPORT:-0}" != "1" ]] || return 1
    [[ "$ENGINE" == "chrome" ]] || return 1

    for arg in "$@"; do
        [[ "$arg" == "--device" ]] && return 1
        [[ "$arg" == "open" ]] && { return 0; }
    done
    return 1
}

if should_apply_default_viewport "$@"; then
    "$AGENT_BROWSER_BIN" --cdp "$WS" set viewport "$DEFAULT_VIEWPORT_WIDTH" "$DEFAULT_VIEWPORT_HEIGHT" 2>/dev/null || true
fi

mapfile -t __sf_browser_command_parts < <(extract_command_and_target "$@")
__sf_browser_command="${__sf_browser_command_parts[0]:-}"
__sf_browser_target="${__sf_browser_command_parts[1]:-}"
mapfile -t __sf_browser_eval_context < <(extract_eval_context_args "$@")

# Submit buttons need form activation semantics that the raw click path sometimes misses
if [[ "$__sf_browser_command" == "click" && -n "$__sf_browser_target" ]] && selector_needs_submit_semantics "$__sf_browser_target" "${__sf_browser_eval_context[@]}"; then
    submit_via_form "$__sf_browser_target" "${__sf_browser_eval_context[@]}"
    exit 0
fi

# --- Execute ---

"$AGENT_BROWSER_BIN" --cdp "$WS" "$@"
EXIT_CODE=$?

# Clean up only the current tab for one-shot artifact commands.
case "${1:-}" in
    screenshot|pdf)
        close_current_tab "${__sf_browser_eval_context[@]}"
        ;;
esac

exit $EXIT_CODE
