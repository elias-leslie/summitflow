#!/usr/bin/env bash
#
# sf - SummitFlow Fast CLI
# Lightweight wrapper for common SummitFlow API operations
#
# Usage:
#   sf context <task-id>     Get full task context (TOON format)
#   sf ready                 Find work (ready tasks)
#   sf approve <task-id>     Approve a task plan
#   sf step pass <task> <sub> <step#>   Mark step done
#   sf subtask pass <task> <sub>        Mark subtask done
#   sf health                Quality gate status
#   sf logs <task-id>        Get task progress logs
#   sf export <task-id>      Export task as JSON
#   sf quick <template> <title>  Create task from template
#

set -euo pipefail

API="http://localhost:8001/api"
PROJECT=""

# Auto-detect project from current working directory
detect_project() {
    PROJECT=$(curl -sf -H "X-Cwd: $(pwd)" "$API/context/project" 2>/dev/null | jq -r '.project_id // "summitflow"')
}

# Show usage
usage() {
    echo "sf - SummitFlow Fast CLI"
    echo ""
    echo "Usage:"
    echo "  sf context <task-id>              Get full task context (TOON format)"
    echo "  sf ready                          Find work (ready tasks)"
    echo "  sf approve <task-id>              Approve a task plan"
    echo "  sf step pass <task> <sub> <step#> Mark step done"
    echo "  sf subtask pass <task> <sub>      Mark subtask done"
    echo "  sf health                         Quality gate status"
    echo "  sf logs <task-id>                 Get task progress logs"
    echo "  sf export <task-id>               Export task as JSON"
    echo "  sf quick <template> <title>       Create task from template"
    echo "  sf project                        Show current project"
    echo ""
    echo "Templates: bug-fix, add-endpoint, add-component"
}

# Main command dispatch
main() {
    if [[ $# -eq 0 ]]; then
        usage
        exit 0
    fi

    local cmd="$1"
    shift

    case "$cmd" in
        project)
            detect_project
            echo "$PROJECT"
            ;;

        context)
            if [[ $# -lt 1 ]]; then
                echo "Usage: sf context <task-id>" >&2
                exit 1
            fi
            detect_project
            curl -sf "$API/projects/$PROJECT/tasks/$1/context"
            ;;

        ready)
            detect_project
            curl -sf "$API/projects/$PROJECT/tasks/ready?format=toon"
            ;;

        approve)
            if [[ $# -lt 1 ]]; then
                echo "Usage: sf approve <task-id>" >&2
                exit 1
            fi
            detect_project
            curl -sf -X POST "$API/projects/$PROJECT/tasks/$1/approve" | jq .
            ;;

        step)
            if [[ $# -lt 4 ]] || [[ "$1" != "pass" ]]; then
                echo "Usage: sf step pass <task-id> <subtask-id> <step#>" >&2
                exit 1
            fi
            shift  # remove 'pass'
            local task="$1" sub="$2" step="$3"
            detect_project
            curl -sf -X PATCH "$API/projects/$PROJECT/tasks/$task/subtasks/$task-$sub/steps/$step/status" \
                -H "Content-Type: application/json" \
                -d '{"passes":true}' | jq .
            ;;

        subtask)
            if [[ $# -lt 3 ]] || [[ "$1" != "pass" ]]; then
                echo "Usage: sf subtask pass <task-id> <subtask-id>" >&2
                exit 1
            fi
            shift  # remove 'pass'
            local task="$1" sub="$2"
            detect_project
            curl -sf -X PATCH "$API/projects/$PROJECT/tasks/$task/subtasks/$task-$sub" \
                -H "Content-Type: application/json" \
                -d '{"passes":true}' | jq .
            ;;

        health)
            # Try quality-gate first, fall back to basic health
            curl -sf "$API/health/quality-gate" 2>/dev/null | jq . || \
            curl -sf "http://localhost:8001/health" | jq .
            ;;

        logs)
            if [[ $# -lt 1 ]]; then
                echo "Usage: sf logs <task-id>" >&2
                exit 1
            fi
            detect_project
            curl -sf "$API/projects/$PROJECT/tasks/$1/logs"
            ;;

        export)
            if [[ $# -lt 1 ]]; then
                echo "Usage: sf export <task-id>" >&2
                exit 1
            fi
            detect_project
            curl -sf "$API/projects/$PROJECT/tasks/$1/export" | jq .
            ;;

        quick)
            if [[ $# -lt 2 ]]; then
                echo "Usage: sf quick <template> <title>" >&2
                echo "Templates: bug-fix, add-endpoint, add-component" >&2
                exit 1
            fi
            local template="$1" title="$2"
            detect_project
            # Generate plan from template
            local plan
            plan=$(curl -sf -X POST "$API/projects/$PROJECT/tasks/quick-plan" \
                -H "Content-Type: application/json" \
                -d "{\"title\":\"$title\",\"template\":\"$template\",\"description\":\"$title\",\"params\":{}}")

            if [[ -z "$plan" ]] || [[ "$plan" == "null" ]]; then
                echo "Error: Failed to generate plan" >&2
                exit 1
            fi

            # Import the generated plan
            local result
            result=$(echo "$plan" | curl -sf -X POST "$API/projects/$PROJECT/tasks" \
                -H "Content-Type: application/json" \
                -d @-)

            local task_id
            task_id=$(echo "$result" | jq -r '.id // .task_id // empty')
            if [[ -n "$task_id" ]]; then
                echo "Created: $task_id"
            else
                echo "$result"
            fi
            ;;

        -h|--help|help)
            usage
            ;;

        *)
            echo "Unknown command: $cmd" >&2
            usage >&2
            exit 1
            ;;
    esac
}

main "$@"
