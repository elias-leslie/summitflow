#!/bin/bash
# st - SummitFlow Tasks CLI
# Issue tracking for all projects via SummitFlow Tasks API

set -e

API_BASE="${ST_API_BASE:-http://localhost:8001/api}"
PROJECT_ID="${ST_PROJECT_ID:-summitflow}"

# Color output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Help text
show_help() {
    cat << 'EOF'
st - SummitFlow Tasks CLI

USAGE:
    st <command> [options]

COMMANDS:
    create <title>     Create a new task
    list               List tasks
    ready              List ready (unblocked) tasks
    blocked            List blocked tasks
    show <id>          Show task details
    update <id>        Update task fields
    close <id>         Close/complete a task (--force to bypass criteria check)
    dep add            Add dependency
    dep list           List dependencies
    dep rm             Remove dependency
    feature list       List features
    feature show <id>  Show feature details
    feature start <id> Create task for feature
    component list     List components
    component show     Show component details
    capability list    List capabilities
    capability show    Show capability details
    test list          List tests
    test run           Run tests
    test import        Import tests
    session list       List agent sessions
    session recent     Show recent sessions

ENVIRONMENT:
    ST_PROJECT_ID      Project ID (default: summitflow)
    ST_API_BASE        API base URL (default: http://localhost:8001/api)

TASK TYPES:
    feature    Feature implementation (validates criteria on close)
    bug        Bug fix
    task       General task

EXAMPLES:
    # Create tasks
    st create "Fix: login bug" -t bug -p 1 -l "complexity:small,domains:backend"
    st create "Add auth" -t feature -p 2 -l "complexity:medium,domains:backend"

    # Work with tasks
    st ready                                    # Show unblocked tasks
    st list --status pending --type bug         # Filter tasks
    st update task-123 --status running         # Start working
    st close task-123 --reason "Done"           # Complete task
    st close task-123 --force                   # Bypass criteria validation

    # Manage features
    st feature list                             # List features
    st feature show FEAT-001                    # Show feature details
    st feature start FEAT-001 -p 1              # Create task for feature

    # Dependencies
    st dep add task-456 task-123 --type blocks

See 'st <command> --help' for command-specific help.
EOF
}

# Create task
cmd_create() {
    local title=""
    local description=""
    local priority=2
    local labels=""
    local task_type="task"
    local parent_id=""

    # Parse arguments
    while [[ $# -gt 0 ]]; do
        case $1 in
            -d|--description)
                description="$2"
                shift 2
                ;;
            -p|--priority)
                priority="$2"
                shift 2
                ;;
            -l|--labels)
                labels="$2"
                shift 2
                ;;
            -t|--type)
                task_type="$2"
                shift 2
                ;;
            --parent)
                parent_id="$2"
                shift 2
                ;;
            --json)
                JSON_OUTPUT=1
                shift
                ;;
            -h|--help)
                cat << 'EOF'
st create - Create a new task

USAGE:
    st create <title> [options]

OPTIONS:
    -d, --description <text>   Task description
    -p, --priority <0-4>       Priority (0=critical, 2=medium default, 4=backlog)
    -l, --labels <labels>      Comma-separated labels (complexity:small,domains:backend)
    -t, --type <type>          Task type: feature, bug, task (default: task)
    --parent <task-id>         Parent task ID for subtasks
    --json                     Output as JSON
EOF
                return 0
                ;;
            -*)
                echo -e "${RED}Unknown option: $1${NC}" >&2
                return 1
                ;;
            *)
                if [[ -z "$title" ]]; then
                    title="$1"
                fi
                shift
                ;;
        esac
    done

    if [[ -z "$title" ]]; then
        echo -e "${RED}Error: Title is required${NC}" >&2
        return 1
    fi

    # Build JSON payload
    local json_data
    json_data=$(jq -n \
        --arg title "$title" \
        --arg description "$description" \
        --argjson priority "$priority" \
        --arg task_type "$task_type" \
        --arg parent_id "$parent_id" \
        --arg labels "$labels" \
        '{
            title: $title,
            priority: $priority,
            task_type: $task_type
        }
        + (if $description != "" then {description: $description} else {} end)
        + (if $parent_id != "" then {parent_task_id: $parent_id} else {} end)
        + (if $labels != "" then {labels: ($labels | split(","))} else {labels: []} end)
        ')

    local response
    response=$(curl -s -X POST "${API_BASE}/projects/${PROJECT_ID}/tasks" \
        -H "Content-Type: application/json" \
        -d "$json_data")

    if [[ -n "${JSON_OUTPUT:-}" ]]; then
        echo "$response" | jq '.'
    else
        local task_id title priority task_type
        task_id=$(echo "$response" | jq -r '.id')
        title=$(echo "$response" | jq -r '.title')
        priority=$(echo "$response" | jq -r '.priority')
        task_type=$(echo "$response" | jq -r '.task_type')
        labels=$(echo "$response" | jq -r '.labels | join(",")')

        echo -e "${GREEN}Created task:${NC} $task_id"
        echo -e "  Title:    $title"
        echo -e "  Type:     $task_type"
        echo -e "  Priority: P$priority"
        [[ -n "$labels" ]] && echo -e "  Labels:   $labels"
    fi
}

# List tasks
cmd_list() {
    local status=""
    local task_type=""
    local priority=""
    local labels=""
    local limit=50

    while [[ $# -gt 0 ]]; do
        case $1 in
            -s|--status)
                status="$2"
                shift 2
                ;;
            -t|--type)
                task_type="$2"
                shift 2
                ;;
            -p|--priority)
                priority="$2"
                shift 2
                ;;
            -l|--labels)
                labels="$2"
                shift 2
                ;;
            --limit)
                limit="$2"
                shift 2
                ;;
            --ready)
                cmd_ready "$@"
                return
                ;;
            --json)
                JSON_OUTPUT=1
                shift
                ;;
            -h|--help)
                cat << 'EOF'
st list - List tasks

USAGE:
    st list [options]

OPTIONS:
    -s, --status <status>      Filter by status (pending, running, completed, failed)
    -t, --type <type>          Filter by type (feature, bug, task)
    -p, --priority <0-4>       Filter by priority
    -l, --labels <labels>      Filter by labels
    --limit <n>                Max results (default: 50)
    --ready                    Show only ready (unblocked) tasks
    --json                     Output as JSON
EOF
                return 0
                ;;
            *)
                shift
                ;;
        esac
    done

    # Build query string
    local query="limit=$limit"
    [[ -n "$status" ]] && query="$query&status=$status"
    [[ -n "$task_type" ]] && query="$query&type=$task_type"
    [[ -n "$priority" ]] && query="$query&priority=$priority"
    [[ -n "$labels" ]] && query="$query&labels=$labels"

    local response
    response=$(curl -s "${API_BASE}/projects/${PROJECT_ID}/tasks?$query")

    if [[ -n "${JSON_OUTPUT:-}" ]]; then
        echo "$response" | jq '.'
    else
        local count
        count=$(echo "$response" | jq '.tasks | length')
        echo -e "${BLUE}Tasks ($count):${NC}\n"

        echo "$response" | jq -r '.tasks[] |
            "\(.id) [\(.status)] P\(.priority) [\(.task_type)] \(.title)"
            + (if .labels | length > 0 then "\n      Labels: " + (.labels | join(", ")) else "" end)' | \
        while IFS= read -r line; do
            # Color status
            if [[ "$line" =~ \[pending\] ]]; then
                echo -e "${YELLOW}$line${NC}"
            elif [[ "$line" =~ \[running\] ]]; then
                echo -e "${BLUE}$line${NC}"
            elif [[ "$line" =~ \[completed\] ]]; then
                echo -e "${GREEN}$line${NC}"
            elif [[ "$line" =~ \[failed\] ]]; then
                echo -e "${RED}$line${NC}"
            else
                echo "$line"
            fi
        done
    fi
}

# Ready tasks (unblocked)
cmd_ready() {
    local limit=50

    while [[ $# -gt 0 ]]; do
        case $1 in
            --limit)
                limit="$2"
                shift 2
                ;;
            --json)
                JSON_OUTPUT=1
                shift
                ;;
            -h|--help)
                echo "st ready - List ready (unblocked) tasks"
                echo ""
                echo "USAGE: st ready [--limit n] [--json]"
                return 0
                ;;
            *)
                shift
                ;;
        esac
    done

    local response
    response=$(curl -s "${API_BASE}/projects/${PROJECT_ID}/tasks/ready?limit=$limit")

    if [[ -n "${JSON_OUTPUT:-}" ]]; then
        echo "$response" | jq '.'
    else
        local count
        count=$(echo "$response" | jq '.tasks | length')
        echo -e "${GREEN}Ready tasks ($count):${NC}\n"

        echo "$response" | jq -r '.tasks[] |
            "\(.id) P\(.priority) [\(.task_type)] \(.title)"
            + (if .labels | length > 0 then "\n      Labels: " + (.labels | join(", ")) else "" end)'
    fi
}

# Blocked tasks
cmd_blocked() {
    local limit=50

    while [[ $# -gt 0 ]]; do
        case $1 in
            --limit)
                limit="$2"
                shift 2
                ;;
            --json)
                JSON_OUTPUT=1
                shift
                ;;
            *)
                shift
                ;;
        esac
    done

    local response
    response=$(curl -s "${API_BASE}/projects/${PROJECT_ID}/tasks/blocked?limit=$limit")

    if [[ -n "${JSON_OUTPUT:-}" ]]; then
        echo "$response" | jq '.'
    else
        local count
        count=$(echo "$response" | jq '.tasks | length')
        echo -e "${RED}Blocked tasks ($count):${NC}\n"

        echo "$response" | jq -r '.tasks[] |
            "\(.id) P\(.priority) [\(.task_type)] \(.title)"'
    fi
}

# Show task details
cmd_show() {
    local task_id="$1"
    shift || true

    if [[ -z "$task_id" ]]; then
        echo -e "${RED}Error: Task ID required${NC}" >&2
        return 1
    fi

    while [[ $# -gt 0 ]]; do
        case $1 in
            --json)
                JSON_OUTPUT=1
                shift
                ;;
            *)
                shift
                ;;
        esac
    done

    local response
    response=$(curl -s "${API_BASE}/projects/${PROJECT_ID}/tasks/${task_id}")

    # Check for error
    if echo "$response" | jq -e '.detail' >/dev/null 2>&1; then
        echo -e "${RED}Error: $(echo "$response" | jq -r '.detail')${NC}" >&2
        return 1
    fi

    if [[ -n "${JSON_OUTPUT:-}" ]]; then
        echo "$response" | jq '.'
    else
        echo -e "${BLUE}Task: $(echo "$response" | jq -r '.id')${NC}"
        echo "$response" | jq -r '"
Title:       \(.title)
Type:        \(.task_type)
Status:      \(.status)
Priority:    P\(.priority)
Labels:      \(.labels | join(", "))
Parent:      \(.parent_task_id // "none")
Created:     \(.created_at)
Description: \(.description // "(none)")
"'
    fi
}

# Update task
cmd_update() {
    local task_id="$1"
    shift || true

    if [[ -z "$task_id" ]]; then
        echo -e "${RED}Error: Task ID required${NC}" >&2
        return 1
    fi

    local status=""
    local priority=""
    local labels=""
    local task_type=""
    local title=""
    local description=""

    while [[ $# -gt 0 ]]; do
        case $1 in
            -s|--status)
                status="$2"
                shift 2
                ;;
            -p|--priority)
                priority="$2"
                shift 2
                ;;
            -l|--labels)
                labels="$2"
                shift 2
                ;;
            -t|--type)
                task_type="$2"
                shift 2
                ;;
            --title)
                title="$2"
                shift 2
                ;;
            -d|--description)
                description="$2"
                shift 2
                ;;
            --json)
                JSON_OUTPUT=1
                shift
                ;;
            -h|--help)
                cat << 'EOF'
st update - Update task fields

USAGE:
    st update <task-id> [options]

OPTIONS:
    -s, --status <status>      New status (pending, running, paused, completed, failed)
    -p, --priority <0-4>       New priority
    -l, --labels <labels>      New labels (comma-separated)
    -t, --type <type>          New type (feature, bug, task)
    --title <title>            New title
    -d, --description <text>   New description
    --json                     Output as JSON
EOF
                return 0
                ;;
            *)
                shift
                ;;
        esac
    done

    # Handle status updates via /status endpoint
    if [[ -n "$status" ]]; then
        local json_data
        json_data=$(jq -n --arg status "$status" '{status: $status}')

        local response
        response=$(curl -s -X PATCH "${API_BASE}/projects/${PROJECT_ID}/tasks/${task_id}/status" \
            -H "Content-Type: application/json" \
            -d "$json_data")

        if echo "$response" | jq -e '.detail' >/dev/null 2>&1; then
            echo -e "${RED}Error: $(echo "$response" | jq -r '.detail')${NC}" >&2
            return 1
        fi

        if [[ -n "${JSON_OUTPUT:-}" ]]; then
            echo "$response" | jq '.'
        else
            echo -e "${GREEN}Updated task $task_id status to: $status${NC}"
        fi
        return
    fi

    # Build update payload for other fields
    local json_data="{}"
    [[ -n "$priority" ]] && json_data=$(echo "$json_data" | jq --argjson p "$priority" '. + {priority: $p}')
    [[ -n "$labels" ]] && json_data=$(echo "$json_data" | jq --arg l "$labels" '. + {labels: ($l | split(","))}')
    [[ -n "$task_type" ]] && json_data=$(echo "$json_data" | jq --arg t "$task_type" '. + {task_type: $t}')
    [[ -n "$title" ]] && json_data=$(echo "$json_data" | jq --arg t "$title" '. + {title: $t}')
    [[ -n "$description" ]] && json_data=$(echo "$json_data" | jq --arg d "$description" '. + {description: $d}')

    if [[ "$json_data" == "{}" ]]; then
        echo -e "${YELLOW}No updates specified${NC}"
        return 0
    fi

    local response
    response=$(curl -s -X PATCH "${API_BASE}/projects/${PROJECT_ID}/tasks/${task_id}" \
        -H "Content-Type: application/json" \
        -d "$json_data")

    if echo "$response" | jq -e '.detail' >/dev/null 2>&1; then
        echo -e "${RED}Error: $(echo "$response" | jq -r '.detail')${NC}" >&2
        return 1
    fi

    if [[ -n "${JSON_OUTPUT:-}" ]]; then
        echo "$response" | jq '.'
    else
        echo -e "${GREEN}Updated task: $task_id${NC}"
    fi
}

# Close task
cmd_close() {
    # Check for help first
    if [[ "$1" == "-h" || "$1" == "--help" ]]; then
        cat << 'EOF'
st close - Close/complete a task

USAGE:
    st close <task-id> [options]

OPTIONS:
    -r, --reason <text>    Reason for closing (appended to description)
    -f, --force            Bypass acceptance criteria validation
    --json                 Output as JSON

NOTE:
    For feature-type tasks linked to a feature, all acceptance criteria
    must be marked as passed before closing. Use --force to bypass.
EOF
        return 0
    fi

    local task_id="$1"
    shift || true

    if [[ -z "$task_id" ]]; then
        echo -e "${RED}Error: Task ID required${NC}" >&2
        return 1
    fi

    local reason=""
    local force=false

    while [[ $# -gt 0 ]]; do
        case $1 in
            -r|--reason)
                reason="$2"
                shift 2
                ;;
            -f|--force)
                force=true
                shift
                ;;
            --json)
                JSON_OUTPUT=1
                shift
                ;;
            *)
                shift
                ;;
        esac
    done

    local json_data
    json_data=$(jq -n --argjson force "$force" '{status: "completed", force: $force}')

    local response
    response=$(curl -s -X PATCH "${API_BASE}/projects/${PROJECT_ID}/tasks/${task_id}/status" \
        -H "Content-Type: application/json" \
        -d "$json_data")

    if echo "$response" | jq -e '.detail' >/dev/null 2>&1; then
        echo -e "${RED}Error: $(echo "$response" | jq -r '.detail')${NC}" >&2
        return 1
    fi

    # Add reason to description if provided
    if [[ -n "$reason" ]]; then
        local current_desc
        current_desc=$(echo "$response" | jq -r '.description // ""')
        local new_desc="$current_desc

Closed: $reason"

        curl -s -X PATCH "${API_BASE}/projects/${PROJECT_ID}/tasks/${task_id}" \
            -H "Content-Type: application/json" \
            -d "$(jq -n --arg d "$new_desc" '{description: $d}')" > /dev/null
    fi

    if [[ -n "${JSON_OUTPUT:-}" ]]; then
        echo "$response" | jq '.'
    else
        echo -e "${GREEN}Closed task: $task_id${NC}"
        [[ -n "$reason" ]] && echo -e "  Reason: $reason"
    fi
}

# Dependency commands
cmd_dep() {
    local subcmd="$1"
    shift || true

    case "$subcmd" in
        add)
            cmd_dep_add "$@"
            ;;
        list|ls)
            cmd_dep_list "$@"
            ;;
        rm|remove)
            cmd_dep_rm "$@"
            ;;
        *)
            cat << 'EOF'
st dep - Manage task dependencies

USAGE:
    st dep <subcommand> [options]

SUBCOMMANDS:
    add <task-id> <depends-on-id>   Add dependency
    list <task-id>                  List dependencies
    rm <task-id> <depends-on-id>    Remove dependency

EXAMPLES:
    st dep add task-456 task-123 --type blocks
    st dep list task-456
EOF
            ;;
    esac
}

cmd_dep_add() {
    local task_id="$1"
    local depends_on="$2"
    shift 2 || true

    if [[ -z "$task_id" || -z "$depends_on" ]]; then
        echo -e "${RED}Error: Both task-id and depends-on-id required${NC}" >&2
        return 1
    fi

    local dep_type="blocks"

    while [[ $# -gt 0 ]]; do
        case $1 in
            -t|--type)
                dep_type="$2"
                shift 2
                ;;
            --json)
                JSON_OUTPUT=1
                shift
                ;;
            *)
                shift
                ;;
        esac
    done

    local json_data
    json_data=$(jq -n \
        --arg depends_on "$depends_on" \
        --arg dep_type "$dep_type" \
        '{depends_on_task_id: $depends_on, dependency_type: $dep_type}')

    local response
    response=$(curl -s -X POST "${API_BASE}/projects/${PROJECT_ID}/tasks/${task_id}/dependencies" \
        -H "Content-Type: application/json" \
        -d "$json_data")

    if echo "$response" | jq -e '.detail' >/dev/null 2>&1; then
        echo -e "${RED}Error: $(echo "$response" | jq -r '.detail')${NC}" >&2
        return 1
    fi

    if [[ -n "${JSON_OUTPUT:-}" ]]; then
        echo "$response" | jq '.'
    else
        echo -e "${GREEN}Added dependency: $task_id -> $depends_on ($dep_type)${NC}"
    fi
}

cmd_dep_list() {
    local task_id="$1"
    shift || true

    if [[ -z "$task_id" ]]; then
        echo -e "${RED}Error: Task ID required${NC}" >&2
        return 1
    fi

    while [[ $# -gt 0 ]]; do
        case $1 in
            --json)
                JSON_OUTPUT=1
                shift
                ;;
            *)
                shift
                ;;
        esac
    done

    local response
    response=$(curl -s "${API_BASE}/projects/${PROJECT_ID}/tasks/${task_id}/dependencies")

    if [[ -n "${JSON_OUTPUT:-}" ]]; then
        echo "$response" | jq '.'
    else
        local count
        count=$(echo "$response" | jq 'length')
        echo -e "${BLUE}Dependencies for $task_id ($count):${NC}\n"

        echo "$response" | jq -r '.[] |
            "\(.depends_on_task_id) [\(.depends_on_status)] \(.dependency_type) - \(.depends_on_title)"'
    fi
}

cmd_dep_rm() {
    local task_id="$1"
    local depends_on="$2"
    shift 2 || true

    if [[ -z "$task_id" || -z "$depends_on" ]]; then
        echo -e "${RED}Error: Both task-id and depends-on-id required${NC}" >&2
        return 1
    fi

    local dep_type=""

    while [[ $# -gt 0 ]]; do
        case $1 in
            -t|--type)
                dep_type="$2"
                shift 2
                ;;
            --json)
                JSON_OUTPUT=1
                shift
                ;;
            *)
                shift
                ;;
        esac
    done

    local url="${API_BASE}/projects/${PROJECT_ID}/tasks/${task_id}/dependencies/${depends_on}"
    [[ -n "$dep_type" ]] && url="$url?dependency_type=$dep_type"

    local response
    response=$(curl -s -X DELETE "$url")

    if [[ -n "${JSON_OUTPUT:-}" ]]; then
        echo "$response" | jq '.'
    else
        local status
        status=$(echo "$response" | jq -r '.status')
        if [[ "$status" == "removed" ]]; then
            echo -e "${GREEN}Removed dependency: $task_id -> $depends_on${NC}"
        else
            echo -e "${YELLOW}Dependency not found${NC}"
        fi
    fi
}

# Feature commands
cmd_feature() {
    local subcmd="$1"
    shift || true

    case "$subcmd" in
        list|ls)
            cmd_feature_list "$@"
            ;;
        show|get)
            cmd_feature_show "$@"
            ;;
        start)
            cmd_feature_start "$@"
            ;;
        *)
            cat << 'EOF'
st feature - Manage features

USAGE:
    st feature <subcommand> [options]

SUBCOMMANDS:
    list                   List features
    show <feature-id>      Show feature details
    start <feature-id>     Create a task for the feature

EXAMPLES:
    st feature list
    st feature show FEAT-001
    st feature start FEAT-001 -p 1
EOF
            ;;
    esac
}

cmd_feature_list() {
    local category=""
    local limit=50

    while [[ $# -gt 0 ]]; do
        case $1 in
            -c|--category)
                category="$2"
                shift 2
                ;;
            --limit)
                limit="$2"
                shift 2
                ;;
            --json)
                JSON_OUTPUT=1
                shift
                ;;
            -h|--help)
                cat << 'EOF'
st feature list - List features

USAGE:
    st feature list [options]

OPTIONS:
    -c, --category <cat>   Filter by category
    --limit <n>            Max results (default: 50)
    --json                 Output as JSON
EOF
                return 0
                ;;
            *)
                shift
                ;;
        esac
    done

    local query="limit=$limit"
    [[ -n "$category" ]] && query="$query&category=$category"

    local response
    response=$(curl -s "${API_BASE}/projects/${PROJECT_ID}/features?$query")

    if [[ -n "${JSON_OUTPUT:-}" ]]; then
        echo "$response" | jq '.'
    else
        local count
        count=$(echo "$response" | jq '.features | length')
        echo -e "${BLUE}Features ($count):${NC}\n"

        echo "$response" | jq -r '.features[] |
            "\(.feature_id) [\(.status // "active")] \(.name)"
            + (if .category then " (\(.category))" else "" end)
            + "\n      Criteria: \(.criteria_passed // 0)/\(.criteria_total // 0) passed"' | \
        while IFS= read -r line; do
            echo "$line"
        done
    fi
}

cmd_feature_show() {
    local feature_id="$1"
    shift || true

    if [[ -z "$feature_id" ]]; then
        echo -e "${RED}Error: Feature ID required (e.g., FEAT-001)${NC}" >&2
        return 1
    fi

    while [[ $# -gt 0 ]]; do
        case $1 in
            --json)
                JSON_OUTPUT=1
                shift
                ;;
            *)
                shift
                ;;
        esac
    done

    local response
    response=$(curl -s "${API_BASE}/projects/${PROJECT_ID}/features/${feature_id}")

    # Check for error
    if echo "$response" | jq -e '.detail' >/dev/null 2>&1; then
        echo -e "${RED}Error: $(echo "$response" | jq -r '.detail')${NC}" >&2
        return 1
    fi

    if [[ -n "${JSON_OUTPUT:-}" ]]; then
        echo "$response" | jq '.'
    else
        echo -e "${BLUE}Feature: $(echo "$response" | jq -r '.feature_id')${NC}"
        echo "$response" | jq -r '"
Name:        \(.name)
Category:    \(.category // "(none)")
Status:      \(.status // "active")
Priority:    \(.priority // 5)
Description: \(.description // "(none)")

Acceptance Criteria (\(.criteria_passed // 0)/\(.criteria_total // 0) passed):"'

        # List criteria
        echo "$response" | jq -r '.acceptance_criteria // [] | to_entries[] |
            "  [\(if .value.passes then "✓" else " " end)] AC-\(.key + 1): \(.value.description)"'
    fi
}

cmd_feature_start() {
    local feature_id="$1"
    shift || true

    if [[ -z "$feature_id" ]]; then
        echo -e "${RED}Error: Feature ID required (e.g., FEAT-001)${NC}" >&2
        return 1
    fi

    local priority=2
    local title=""

    while [[ $# -gt 0 ]]; do
        case $1 in
            -p|--priority)
                priority="$2"
                shift 2
                ;;
            -t|--title)
                title="$2"
                shift 2
                ;;
            --json)
                JSON_OUTPUT=1
                shift
                ;;
            -h|--help)
                cat << 'EOF'
st feature start - Create a task for a feature

USAGE:
    st feature start <feature-id> [options]

OPTIONS:
    -p, --priority <0-4>   Task priority (default: 2)
    -t, --title <title>    Custom task title (default: "Implement: <feature-name>")
    --json                 Output as JSON
EOF
                return 0
                ;;
            *)
                shift
                ;;
        esac
    done

    # Get feature details first
    local feature_response
    feature_response=$(curl -s "${API_BASE}/projects/${PROJECT_ID}/features/${feature_id}")

    if echo "$feature_response" | jq -e '.detail' >/dev/null 2>&1; then
        echo -e "${RED}Error: $(echo "$feature_response" | jq -r '.detail')${NC}" >&2
        return 1
    fi

    # Extract feature info
    local db_id feature_name
    db_id=$(echo "$feature_response" | jq -r '.id')
    feature_name=$(echo "$feature_response" | jq -r '.name')

    # Default title if not provided
    [[ -z "$title" ]] && title="Implement: $feature_name"

    # Create task linked to feature
    local json_data
    json_data=$(jq -n \
        --arg title "$title" \
        --argjson priority "$priority" \
        --argjson feature_id "$db_id" \
        '{
            title: $title,
            priority: $priority,
            task_type: "feature",
            feature_id: $feature_id,
            labels: ["complexity:medium", "domains:backend"]
        }')

    local response
    response=$(curl -s -X POST "${API_BASE}/projects/${PROJECT_ID}/tasks" \
        -H "Content-Type: application/json" \
        -d "$json_data")

    if echo "$response" | jq -e '.detail' >/dev/null 2>&1; then
        echo -e "${RED}Error: $(echo "$response" | jq -r '.detail')${NC}" >&2
        return 1
    fi

    if [[ -n "${JSON_OUTPUT:-}" ]]; then
        echo "$response" | jq '.'
    else
        local task_id
        task_id=$(echo "$response" | jq -r '.id')
        echo -e "${GREEN}Created task:${NC} $task_id"
        echo -e "  Title:    $title"
        echo -e "  Feature:  $feature_id"
        echo -e "  Priority: P$priority"
    fi
}

# Component commands
cmd_component() {
    local subcmd="$1"
    shift || true

    case "$subcmd" in
        list|ls)
            cmd_component_list "$@"
            ;;
        show|get)
            cmd_component_show "$@"
            ;;
        *)
            cat << 'EOF'
st component - Manage components

USAGE:
    st component <subcommand> [options]

SUBCOMMANDS:
    list                   List components
    show <component-id>    Show component details

EXAMPLES:
    st component list
    st component show comp-001
EOF
            ;;
    esac
}

cmd_component_list() {
    local response
    response=$(curl -s "${API_BASE}/projects/${PROJECT_ID}/components")

    if [[ -n "${JSON_OUTPUT:-}" ]]; then
        echo "$response" | jq '.'
    else
        local count
        count=$(echo "$response" | jq 'length')
        echo -e "${BLUE}Components ($count):${NC}\n"

        echo "$response" | jq -r '.[] |
            "\(.component_id) [\(.status // "pending")] \(.name)"
            + "\n      Capabilities: \(.capability_count // 0)"'
    fi
}

cmd_component_show() {
    local component_id="$1"
    shift || true

    if [[ -z "$component_id" ]]; then
        echo -e "${RED}Error: Component ID required${NC}" >&2
        return 1
    fi

    local response
    response=$(curl -s "${API_BASE}/projects/${PROJECT_ID}/components/${component_id}")

    if echo "$response" | jq -e '.detail' >/dev/null 2>&1; then
        echo -e "${RED}Error: $(echo "$response" | jq -r '.detail')${NC}" >&2
        return 1
    fi

    if [[ -n "${JSON_OUTPUT:-}" ]]; then
        echo "$response" | jq '.'
    else
        echo -e "${BLUE}Component: $(echo "$response" | jq -r '.component_id')${NC}"
        echo "$response" | jq -r '"
Name:        \(.name)
Status:      \(.status // "pending")
Priority:    \(.priority // 0)
Description: \(.description // "(none)")
"'
    fi
}

# Capability commands
cmd_capability() {
    local subcmd="$1"
    shift || true

    case "$subcmd" in
        list|ls)
            cmd_capability_list "$@"
            ;;
        show|get)
            cmd_capability_show "$@"
            ;;
        lock)
            cmd_capability_lock "$@"
            ;;
        verify)
            cmd_capability_verify "$@"
            ;;
        *)
            cat << 'EOF'
st capability - Manage capabilities

USAGE:
    st capability <subcommand> [options]

SUBCOMMANDS:
    list                    List capabilities
    show <capability-id>    Show capability details
    lock <capability-id>    Lock a capability
    verify <capability-id>  Verify capability (check tests, update status)

EXAMPLES:
    st capability list
    st capability list --component comp-001
    st capability show cap-001
    st capability lock cap-001
    st capability verify cap-001
EOF
            ;;
    esac
}

cmd_capability_list() {
    local component=""

    while [[ $# -gt 0 ]]; do
        case $1 in
            -c|--component)
                component="$2"
                shift 2
                ;;
            --json)
                JSON_OUTPUT=1
                shift
                ;;
            *)
                shift
                ;;
        esac
    done

    local query=""
    [[ -n "$component" ]] && query="?component=$component"

    local response
    response=$(curl -s "${API_BASE}/projects/${PROJECT_ID}/capabilities${query}")

    if [[ -n "${JSON_OUTPUT:-}" ]]; then
        echo "$response" | jq '.'
    else
        local count
        count=$(echo "$response" | jq 'length')
        echo -e "${BLUE}Capabilities ($count):${NC}\n"

        echo "$response" | jq -r '.[] |
            "\(.capability_id) [\(.status // "pending")] \(.name)"
            + (if .locked_at then " [LOCKED]" else "" end)
            + "\n      Component: \(.component_id // "none")"'
    fi
}

cmd_capability_show() {
    local capability_id="$1"
    shift || true

    if [[ -z "$capability_id" ]]; then
        echo -e "${RED}Error: Capability ID required${NC}" >&2
        return 1
    fi

    local response
    response=$(curl -s "${API_BASE}/projects/${PROJECT_ID}/capabilities/${capability_id}")

    if echo "$response" | jq -e '.detail' >/dev/null 2>&1; then
        echo -e "${RED}Error: $(echo "$response" | jq -r '.detail')${NC}" >&2
        return 1
    fi

    if [[ -n "${JSON_OUTPUT:-}" ]]; then
        echo "$response" | jq '.'
    else
        echo -e "${BLUE}Capability: $(echo "$response" | jq -r '.capability_id')${NC}"
        echo "$response" | jq -r '"
Name:           \(.name)
Component:      \(.component_id // "none")
Status:         \(.status // "pending")
Priority:       \(.priority // 0)
Locked:         \(.locked_at // "no")
Verification:   \(.verification_url // "(none)")
Description:    \(.description // "(none)")

Linked Tests: \(.tests | length // 0)"'

        # Show linked tests if any with pass/fail status
        echo "$response" | jq -r '.tests // [] | .[] |
            "  - \(.test_id): \(.name) [\(.last_result // "not run")]"'
    fi
}

cmd_capability_lock() {
    local capability_id="$1"
    shift || true

    if [[ -z "$capability_id" ]]; then
        echo -e "${RED}Error: Capability ID required${NC}" >&2
        return 1
    fi

    local response
    response=$(curl -s -X POST "${API_BASE}/projects/${PROJECT_ID}/capabilities/${capability_id}/lock")

    if echo "$response" | jq -e '.detail' >/dev/null 2>&1; then
        echo -e "${RED}Error: $(echo "$response" | jq -r '.detail')${NC}" >&2
        return 1
    fi

    echo -e "${GREEN}Locked capability: $capability_id${NC}"
}

cmd_capability_verify() {
    local capability_id="$1"
    shift || true

    if [[ -z "$capability_id" ]]; then
        echo -e "${RED}Error: Capability ID required${NC}" >&2
        echo "Usage: st capability verify <capability-id>"
        return 1
    fi

    local response
    response=$(curl -s -X POST "${API_BASE}/projects/${PROJECT_ID}/capabilities/${capability_id}/verify")

    if echo "$response" | jq -e '.detail' >/dev/null 2>&1; then
        echo -e "${RED}Error: $(echo "$response" | jq -r '.detail')${NC}" >&2
        return 1
    fi

    if [[ -n "${JSON_OUTPUT:-}" ]]; then
        echo "$response" | jq '.'
    else
        local status passed failed total
        status=$(echo "$response" | jq -r '.capability_status')
        passed=$(echo "$response" | jq -r '.tests_passed')
        failed=$(echo "$response" | jq -r '.tests_failed')
        total=$(echo "$response" | jq -r '.tests_total')

        echo -e "${BLUE}Verification: $capability_id${NC}"
        echo "tests:  $passed/$total passed"
        if [[ "$failed" -gt 0 ]]; then
            echo -e "status: ${RED}$status${NC} ($failed failed)"
        else
            echo -e "status: ${GREEN}$status${NC}"
        fi
    fi
}

# Test commands
cmd_test() {
    local subcmd="$1"
    shift || true

    case "$subcmd" in
        list|ls)
            cmd_test_list "$@"
            ;;
        show|get)
            cmd_test_show "$@"
            ;;
        run)
            cmd_test_run "$@"
            ;;
        import)
            cmd_test_import "$@"
            ;;
        *)
            cat << 'EOF'
st test - Manage tests

USAGE:
    st test <subcommand> [options]

SUBCOMMANDS:
    list                List tests
    show <test-id>      Show test details
    run [options]       Run tests
    import              Import tests from project

EXAMPLES:
    st test list
    st test list --type pytest
    st test run --all
    st test run --test test-001
    st test import --from pytest
EOF
            ;;
    esac
}

cmd_test_list() {
    local test_type=""

    while [[ $# -gt 0 ]]; do
        case $1 in
            -t|--type)
                test_type="$2"
                shift 2
                ;;
            --json)
                JSON_OUTPUT=1
                shift
                ;;
            *)
                shift
                ;;
        esac
    done

    local query=""
    [[ -n "$test_type" ]] && query="?type=$test_type"

    local response
    response=$(curl -s "${API_BASE}/projects/${PROJECT_ID}/tests${query}")

    if [[ -n "${JSON_OUTPUT:-}" ]]; then
        echo "$response" | jq '.'
    else
        local count
        count=$(echo "$response" | jq 'length')
        echo -e "${BLUE}Tests ($count):${NC}\n"

        echo "$response" | jq -r '.[] |
            "\(.test_id) [\(.test_type)] \(.name)"
            + "\n      Last: \(.last_result // "never") (\(.last_duration_ms // 0)ms)"'
    fi
}

cmd_test_show() {
    local test_id="$1"
    shift || true

    if [[ -z "$test_id" ]]; then
        echo -e "${RED}Error: Test ID required${NC}" >&2
        return 1
    fi

    local response
    response=$(curl -s "${API_BASE}/projects/${PROJECT_ID}/tests/${test_id}")

    if echo "$response" | jq -e '.detail' >/dev/null 2>&1; then
        echo -e "${RED}Error: $(echo "$response" | jq -r '.detail')${NC}" >&2
        return 1
    fi

    if [[ -n "${JSON_OUTPUT:-}" ]]; then
        echo "$response" | jq '.'
    else
        echo -e "${BLUE}Test: $(echo "$response" | jq -r '.test_id')${NC}"
        echo "$response" | jq -r '"
Name:        \(.name)
Type:        \(.test_type)
Command:     \(.command // "(none)")
Last Run:    \(.last_run_at // "never")
Last Result: \(.last_result // "never")
Duration:    \(.last_duration_ms // 0)ms
Run Count:   \(.run_count // 0) (pass: \(.pass_count // 0), fail: \(.fail_count // 0))
"'
    fi
}

cmd_test_run() {
    local test_id=""
    local tier=""
    local all=false

    while [[ $# -gt 0 ]]; do
        case $1 in
            -t|--test)
                test_id="$2"
                shift 2
                ;;
            --tier)
                tier="$2"
                shift 2
                ;;
            -a|--all)
                all=true
                shift
                ;;
            --json)
                JSON_OUTPUT=1
                shift
                ;;
            *)
                shift
                ;;
        esac
    done

    if [[ -n "$test_id" ]]; then
        # Run single test
        local response
        response=$(curl -s -X POST "${API_BASE}/projects/${PROJECT_ID}/tests/${test_id}/run")

        if echo "$response" | jq -e '.detail' >/dev/null 2>&1; then
            echo -e "${RED}Error: $(echo "$response" | jq -r '.detail')${NC}" >&2
            return 1
        fi

        if [[ -n "${JSON_OUTPUT:-}" ]]; then
            echo "$response" | jq '.'
        else
            local result
            result=$(echo "$response" | jq -r '.result')
            local duration
            duration=$(echo "$response" | jq -r '.duration_ms')

            if [[ "$result" == "passed" ]]; then
                echo -e "${GREEN}PASSED${NC} $test_id (${duration}ms)"
            else
                echo -e "${RED}FAILED${NC} $test_id (${duration}ms)"
                echo "$response" | jq -r '.output // ""' | head -10
            fi
        fi
    else
        # Run multiple tests
        local json_data="{}"
        [[ -n "$tier" ]] && json_data=$(echo "$json_data" | jq --arg t "$tier" '. + {tier: $t}')

        local response
        response=$(curl -s -X POST "${API_BASE}/projects/${PROJECT_ID}/tests/run" \
            -H "Content-Type: application/json" \
            -d "$json_data")

        if [[ -n "${JSON_OUTPUT:-}" ]]; then
            echo "$response" | jq '.'
        else
            local passed failed
            passed=$(echo "$response" | jq '[.[] | select(.result == "passed")] | length')
            failed=$(echo "$response" | jq '[.[] | select(.result != "passed")] | length')

            echo -e "${BLUE}Test Results:${NC}"
            echo -e "  ${GREEN}Passed:${NC} $passed"
            echo -e "  ${RED}Failed:${NC} $failed"
        fi
    fi
}

cmd_test_import() {
    local source_type="all"

    while [[ $# -gt 0 ]]; do
        case $1 in
            -f|--from)
                source_type="$2"
                shift 2
                ;;
            --json)
                JSON_OUTPUT=1
                shift
                ;;
            *)
                shift
                ;;
        esac
    done

    local json_data
    json_data=$(jq -n --arg s "$source_type" '{source_type: $s, discover: true}')

    local response
    response=$(curl -s -X POST "${API_BASE}/projects/${PROJECT_ID}/tests/import" \
        -H "Content-Type: application/json" \
        -d "$json_data")

    if echo "$response" | jq -e '.detail' >/dev/null 2>&1; then
        echo -e "${RED}Error: $(echo "$response" | jq -r '.detail')${NC}" >&2
        return 1
    fi

    if [[ -n "${JSON_OUTPUT:-}" ]]; then
        echo "$response" | jq '.'
    else
        local imported skipped
        imported=$(echo "$response" | jq -r '.imported_count')
        skipped=$(echo "$response" | jq -r '.skipped_count')

        echo -e "${GREEN}Imported:${NC} $imported tests"
        echo -e "${YELLOW}Skipped:${NC} $skipped (already exist)"

        local errors
        errors=$(echo "$response" | jq -r '.errors | length')
        if [[ "$errors" -gt 0 ]]; then
            echo -e "${RED}Errors:${NC} $errors"
            echo "$response" | jq -r '.errors[]' | head -5
        fi
    fi
}

# Session commands
cmd_session() {
    local subcmd="$1"
    shift || true

    case "$subcmd" in
        list|ls)
            cmd_session_list "$@"
            ;;
        recent)
            cmd_session_recent "$@"
            ;;
        show|get)
            cmd_session_show "$@"
            ;;
        *)
            cat << 'EOF'
st session - Manage agent sessions

USAGE:
    st session <subcommand> [options]

SUBCOMMANDS:
    list                List sessions
    recent              Show recent sessions
    show <session-id>   Show session details

EXAMPLES:
    st session list
    st session recent
    st session show session-001
EOF
            ;;
    esac
}

cmd_session_list() {
    local response
    response=$(curl -s "${API_BASE}/projects/${PROJECT_ID}/sessions")

    if [[ -n "${JSON_OUTPUT:-}" ]]; then
        echo "$response" | jq '.'
    else
        local count
        count=$(echo "$response" | jq 'length')
        echo -e "${BLUE}Sessions ($count):${NC}\n"

        echo "$response" | jq -r '.[] |
            "\(.session_id) [\(.status)] \(.agent_type)"
            + "\n      Tests: \(.tests_passed // 0)/\(.tests_run // 0)"'
    fi
}

cmd_session_recent() {
    local limit=3

    while [[ $# -gt 0 ]]; do
        case $1 in
            -n|--limit)
                limit="$2"
                shift 2
                ;;
            --json)
                JSON_OUTPUT=1
                shift
                ;;
            *)
                shift
                ;;
        esac
    done

    local response
    response=$(curl -s "${API_BASE}/projects/${PROJECT_ID}/sessions/recent?limit=$limit")

    if [[ -n "${JSON_OUTPUT:-}" ]]; then
        echo "$response" | jq '.'
    else
        echo -e "${BLUE}Recent Sessions:${NC}\n"

        echo "$response" | jq -r '.[] |
            "\(.session_id) [\(.status)] \(.agent_type)"
            + "\n      Started: \(.started_at)"
            + "\n      Tests: \(.tests_passed // 0)/\(.tests_run // 0)"
            + "\n      Notes: \(.notes // "(none)")"
            + "\n"'
    fi
}

cmd_session_show() {
    local session_id="$1"
    shift || true

    if [[ -z "$session_id" ]]; then
        echo -e "${RED}Error: Session ID required${NC}" >&2
        return 1
    fi

    local response
    response=$(curl -s "${API_BASE}/projects/${PROJECT_ID}/sessions/${session_id}")

    if echo "$response" | jq -e '.detail' >/dev/null 2>&1; then
        echo -e "${RED}Error: $(echo "$response" | jq -r '.detail')${NC}" >&2
        return 1
    fi

    if [[ -n "${JSON_OUTPUT:-}" ]]; then
        echo "$response" | jq '.'
    else
        echo -e "${BLUE}Session: $(echo "$response" | jq -r '.session_id')${NC}"
        echo "$response" | jq -r '"
Agent:       \(.agent_type)
Status:      \(.status)
Started:     \(.started_at)
Ended:       \(.ended_at // "running")
Tests Run:   \(.tests_run // 0)
Passed:      \(.tests_passed // 0)
Failed:      \(.tests_failed // 0)
Git Commit:  \(.git_commit_sha // "(none)")
Notes:       \(.notes // "(none)")
"'
    fi
}

# Build commands
cmd_build() {
    local subcmd="$1"
    shift || true

    case "$subcmd" in
        status)
            cmd_build_status "$@"
            ;;
        *)
            cat << 'EOF'
st build - Build orchestration

USAGE:
    st build <subcommand> [options]

SUBCOMMANDS:
    status              Show build status

NOTE: Build start/stop not yet implemented (Phase 10)
EOF
            ;;
    esac
}

cmd_build_status() {
    echo -e "${YELLOW}Build status not yet implemented (Phase 10)${NC}"
}

# Bug command
cmd_bug() {
    local capability_id=""
    local reason=""

    while [[ $# -gt 0 ]]; do
        case $1 in
            -c|--capability)
                capability_id="$2"
                shift 2
                ;;
            -r|--reason)
                reason="$2"
                shift 2
                ;;
            --json)
                JSON_OUTPUT=1
                shift
                ;;
            -h|--help)
                cat << 'EOF'
st bug - Create a bug task linked to capability

USAGE:
    st bug create --capability <cap-id> --reason "description"

OPTIONS:
    -c, --capability <id>  Capability ID
    -r, --reason <text>    Bug description
    --json                 Output as JSON

EXAMPLE:
    st bug create --capability cap-001 --reason "Test failure in login flow"
EOF
                return 0
                ;;
            create)
                shift
                ;;
            *)
                shift
                ;;
        esac
    done

    if [[ -z "$capability_id" || -z "$reason" ]]; then
        echo -e "${RED}Error: --capability and --reason required${NC}" >&2
        return 1
    fi

    # Create bug task linked to capability
    local json_data
    json_data=$(jq -n \
        --arg title "Bug: $reason" \
        --arg desc "Linked to capability: $capability_id" \
        '{
            title: $title,
            description: $desc,
            priority: 2,
            task_type: "bug",
            labels: ["complexity:small", "domains:backend"]
        }')

    local response
    response=$(curl -s -X POST "${API_BASE}/projects/${PROJECT_ID}/tasks" \
        -H "Content-Type: application/json" \
        -d "$json_data")

    if echo "$response" | jq -e '.detail' >/dev/null 2>&1; then
        echo -e "${RED}Error: $(echo "$response" | jq -r '.detail')${NC}" >&2
        return 1
    fi

    if [[ -n "${JSON_OUTPUT:-}" ]]; then
        echo "$response" | jq '.'
    else
        local task_id
        task_id=$(echo "$response" | jq -r '.id')
        echo -e "${GREEN}Created bug task:${NC} $task_id"
        echo -e "  Capability: $capability_id"
        echo -e "  Reason: $reason"
    fi
}

# Main entry point
main() {
    local cmd="${1:-}"
    shift || true

    case "$cmd" in
        create|new|add)
            cmd_create "$@"
            ;;
        list|ls)
            cmd_list "$@"
            ;;
        ready)
            cmd_ready "$@"
            ;;
        blocked)
            cmd_blocked "$@"
            ;;
        show|get)
            cmd_show "$@"
            ;;
        update|edit)
            cmd_update "$@"
            ;;
        close|done|complete)
            cmd_close "$@"
            ;;
        dep|dependency)
            cmd_dep "$@"
            ;;
        feature|feat)
            cmd_feature "$@"
            ;;
        component|comp)
            cmd_component "$@"
            ;;
        capability|cap)
            cmd_capability "$@"
            ;;
        test|tests)
            cmd_test "$@"
            ;;
        session|sessions)
            cmd_session "$@"
            ;;
        build)
            cmd_build "$@"
            ;;
        bug)
            cmd_bug "$@"
            ;;
        -h|--help|help|"")
            show_help
            ;;
        *)
            echo -e "${RED}Unknown command: $cmd${NC}" >&2
            echo "Run 'st --help' for usage."
            exit 1
            ;;
    esac
}

main "$@"
