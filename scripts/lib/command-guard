#!/usr/bin/env bash
set -euo pipefail

SCRIPT_PATH="$(readlink -f "${BASH_SOURCE[0]}")"
SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"
SUMMITFLOW_ROOT="$(cd "$SCRIPT_DIR/../.." && pwd)"
PYTHON_BIN="$SUMMITFLOW_ROOT/backend/.venv/bin/python"

if [[ ! -x "$PYTHON_BIN" ]]; then
  echo "Shared command guard unavailable: missing $PYTHON_BIN" >&2
  exit 1
fi

export SF_COMMAND_GUARD_DISABLE=1
unset BASH_ENV
export PYTHONPATH="$SUMMITFLOW_ROOT/backend${PYTHONPATH:+:$PYTHONPATH}"

cd "$SUMMITFLOW_ROOT/backend"

exec "$PYTHON_BIN" -m app.services.command_guard "$@"
