{
  "version": 1,
  "description": "Centralized tool registry — single source of truth for operator tool discovery, redirects, and check-runner configuration.",
  "cmd_start": "(^|&&\\s*|;\\s*)",
  "operator_tools": [
    {
      "id": "service",
      "canonical": "st service",
      "legacy": ["rebuild.sh", "status.sh", "start.sh", "restart.sh", "shutdown.sh"],
      "summary": "Project service lifecycle, rebuild, migrations, systemd sync, and health checks.",
      "safety": "mutating",
      "commands": ["status", "rebuild", "restart", "start", "stop"],
      "examples": ["st service status summitflow", "st service rebuild summitflow", "st service stop"],
      "verify": ["st service status summitflow"]
    },
    {
      "id": "check",
      "canonical": "st check",
      "legacy": ["dt", "dev-tools.sh"],
      "summary": "Quality gates and tool wrappers with TOON output.",
      "safety": "read-mostly",
      "commands": ["--check", "--quick", "pytest", "ruff", "types", "biome", "tsc", "vitest"],
      "examples": ["st check --quick --changed-only", "st check pytest -- backend/tests/cli/test_tools_cli.py"],
      "verify": ["dt --help", "st check --help"]
    },
    {
      "id": "db",
      "canonical": "st db",
      "legacy": ["db"],
      "summary": "Cross-project PostgreSQL inspection and Alembic migration operations.",
      "safety": "mixed",
      "commands": ["tables", "schema", "count", "sample", "query", "exec", "ddl", "migrate"],
      "examples": ["st db tables", "st db migrate status"],
      "verify": ["st db tables"]
    },
    {
      "id": "git",
      "canonical": "st git",
      "legacy": ["commit.sh"],
      "summary": "Managed repository status, sync, task finalization, and commit workflow.",
      "safety": "mutating",
      "commands": ["status", "sync", "finalize-task", "commit"],
      "examples": ["st git status", "st git sync"],
      "verify": ["st git status"]
    },
    {
      "id": "browser",
      "canonical": "st browser",
      "legacy": ["sf-browser"],
      "summary": "Remote browser health, responsive checks, screenshots, snapshots, and DOM evaluation.",
      "safety": "external",
      "commands": ["health", "check", "open", "screenshot", "snapshot", "eval"],
      "examples": ["st browser health", "st browser check http://localhost:3001 /tmp/summitflow.png"],
      "verify": ["st browser health"]
    },
    {
      "id": "web",
      "canonical": "st web",
      "legacy": ["web-research"],
      "summary": "Centralized public web search, research, and fetch through Agent Hub.",
      "safety": "external",
      "commands": ["search", "research", "fetch"],
      "examples": ["st web search --query \"SummitFlow\" --limit 1"],
      "verify": ["st web --help"]
    },
    {
      "id": "backup",
      "canonical": "st backup",
      "legacy": ["backup.sh", "restore.sh", "backup-all.sh", "backup-pending-upload.sh"],
      "summary": "Project/source backup creation, restore preview, schedules, pending drain, and infra backups.",
      "safety": "destructive-with-confirmation",
      "commands": ["list", "create", "restore", "archives", "all", "status", "delete", "drain-pending", "infra", "storage", "testbed"],
      "examples": ["st backup status", "st backup archives", "st backup restore bkp-123 --dry-run"],
      "verify": ["st backup status"]
    },
    {
      "id": "vm",
      "canonical": "st vm",
      "legacy": ["proxmox-vm.sh"],
      "summary": "Proxmox test VM list/status/snapshot/rollback/clone/start/stop/destroy/ip.",
      "safety": "destructive-with-confirmation",
      "commands": ["list", "status", "snapshots", "snapshot", "rollback", "clone", "start", "stop", "destroy", "ip"],
      "examples": ["st vm list", "st vm status 100"],
      "verify": ["st vm --help"]
    },
    {
      "id": "setup",
      "canonical": "st setup",
      "legacy": ["setup-services.sh", "setup-agent-browser.sh", "setup-agent-tooling.sh", "setup-test-dbs.sh"],
      "summary": "Install, PATH, browser, agent tooling, and test database setup.",
      "safety": "mutating",
      "commands": ["services", "browser", "agent-tooling", "test-dbs"],
      "examples": ["st setup services --dry-run", "st setup browser --dry-run"],
      "verify": ["st setup --help"]
    }
  ],
  "wrapper_allowlist": [
    "dt\\b",
    "dev-tools\\.sh\\b",
    "st\\b",
    "db\\b",
    "st\\s+docker\\b"
  ],
  "tools": [
    {
      "name": "pytest",
      "component_id": "sf.dt",
      "redirect_patterns": [
        "(\\.venv/bin/)?pytest\\b",
        "python[0-9.]*\\s+-m\\s+pytest\\b",
        "\\.venv/bin/python.*-m\\s+pytest\\b"
      ],
      "redirect_message": "Use 'st check pytest [args]' — handles venv, TOON output, and project resolution.",
      "dt": {
        "label": "TEST",
        "binary": "pytest",
        "args": "--tb=short -q",
        "count_method": "pytest_parse",
        "working_dir": "test",
        "fallback_global": false,
        "pass_path": false
      }
    },
    {
      "name": "types",
      "component_id": "sf.dt",
      "redirect_patterns": [
        "(\\.venv/bin/)?mypy\\b",
        "(\\.venv/bin/)?\\bty\\b"
      ],
      "redirect_message": "Use 'st check types [args]' — handles venv, TOON output, and project resolution.",
      "dt": {
        "label": "TYPES",
        "binary": "ty",
        "args": "check --output-format concise",
        "count_method": "grep_error",
        "working_dir": "backend",
        "fallback_global": true,
        "pass_path": true
      }
    },
    {
      "name": "ruff",
      "component_id": "sf.dt",
      "redirect_patterns": [
        "(\\.venv/bin/)?ruff\\b"
      ],
      "redirect_message": "Use 'st check ruff [args]' — handles venv, TOON output, and project resolution.",
      "dt": {
        "label": "LINT",
        "binary": "ruff",
        "args": "check --output-format=concise",
        "count_method": "wc_l",
        "working_dir": "backend",
        "fallback_global": true,
        "pass_path": true
      }
    },
  {
    "name": "biome",
      "component_id": "sf.dt",
      "redirect_patterns": [
        "(npx\\s+)?biome\\b"
      ],
      "redirect_message": "Use 'st check biome [args]' — handles TOON output and project detection.",
    "dt": {
      "label": "BIOME",
      "binary": "npx",
      "args": "biome check . --max-diagnostics=100",
      "count_method": "biome_parse",
      "working_dir": "frontend",
      "fallback_global": true,
      "pass_path": false
      }
    },
  {
    "name": "tsc",
      "component_id": "sf.dt",
      "redirect_patterns": [
        "(npx\\s+)?tsc\\b"
      ],
      "redirect_message": "Use 'st check tsc' — handles TOON output and project detection.",
    "dt": {
      "label": "TSC",
      "binary": "npx",
      "args": "tsc --noEmit",
      "count_method": "grep_error_ts",
      "working_dir": "frontend",
      "fallback_global": true,
      "pass_path": false
      }
    },
  {
    "name": "vitest",
      "component_id": "sf.dt",
      "redirect_patterns": [
        "(npx\\s+|pnpm(?:\\s+exec)?\\s+)?vitest\\b"
      ],
      "redirect_message": "Use 'st check vitest [args]' — handles project detection and TOON output.",
    "dt": {
      "label": "VITEST",
      "binary": "vitest",
      "args": "run",
      "count_method": "vitest_parse",
      "working_dir": "frontend",
      "fallback_global": true,
      "pass_path": false
      }
    },
    {
      "name": "sqlfluff",
      "component_id": "sf.dt",
      "redirect_patterns": [
        "(\\.venv/bin/)?sqlfluff\\b"
      ],
      "redirect_message": "Use 'st check sqlfluff' — handles venv, TOON output, project detection.",
      "dt": {
        "label": "SQLFLUFF",
        "binary": "sqlfluff",
        "args": "lint --dialect postgres",
        "count_method": "type_line_count",
        "working_dir": "migrations",
        "fallback_global": true,
        "pass_path": true
      }
    },
    {
      "name": "squawk",
      "component_id": "sf.dt",
      "redirect_patterns": [
        "squawk\\b"
      ],
      "redirect_message": "Use 'st check squawk' — handles TOON output and project detection.",
      "dt": {
        "label": "SQUAWK",
        "binary": "squawk",
        "args": "",
        "count_method": "type_line_count",
        "working_dir": "migrations",
        "fallback_global": true,
        "pass_path": true
      }
    }
  ],
  "docker_redirects": [
    {
      "pattern": "docker\\s+compose\\b",
      "message": "Use 'st docker' for the managed compose stack and named test environments. Commands: st docker status, st docker up, st docker down, st docker logs <service>, st docker restart <service>, st docker build, st docker backup/restore, st docker env-create <name>, st docker env-exec <name> <service> <cmd...>, st docker metrics.",
      "component_id": "sf.docker"
    }
  ],
  "service_redirects": [
    {
      "pattern": "(rebuild|restart|status|start|shutdown|stop)\\.sh\\b",
      "message": "Use 'st service status|rebuild|restart|start|stop' instead of legacy service scripts.",
      "component_id": "sf.scripts"
    },
    {
      "pattern": "commit\\.sh\\b",
      "message": "Use 'st git commit' instead of legacy commit.sh.",
      "component_id": "sf.git"
    },
    {
      "pattern": "(backup|backup-all|backup-pending-upload|restore)\\.sh\\b",
      "message": "Use 'st backup' commands instead of legacy backup scripts. Start with 'st backup --help'.",
      "component_id": "sf.backup"
    },
    {
      "pattern": "sf-browser\\b",
      "message": "Use 'st browser' instead of legacy sf-browser.",
      "component_id": "sf.browser"
    },
    {
      "pattern": "web-research\\b",
      "message": "Use 'st web' instead of legacy web-research.",
      "component_id": "sf.web"
    },
    {
      "pattern": "proxmox-vm\\.sh\\b",
      "message": "Use 'st vm' instead of legacy proxmox-vm.sh.",
      "component_id": "sf.vm"
    },
    {
      "pattern": "setup-(services|agent-browser|agent-tooling|test-dbs)\\.sh\\b",
      "message": "Use 'st setup' instead of legacy setup scripts. Start with 'st setup --help'.",
      "component_id": "sf.setup"
    },
    {
      "pattern": "systemctl\\s+(--user\\s+)?(restart|stop|start|kill|disable|enable)\\s+(summitflow|agent-hub|portfolio|sf-|ah-|hatchet)",
      "message": "Use 'st service rebuild <project>' or 'st service stop' for service management. Never manage services via systemctl directly.",
      "component_id": "sf.scripts"
    },
    {
      "pattern": "(pkill|killall)\\b.*(uvicorn|gunicorn|next|hatchet)",
      "message": "Never kill service processes directly. Use 'st service rebuild <project>' or 'st service stop'.",
      "component_id": "sf.scripts"
    },
    {
      "pattern": "(\\.venv/bin/)?(uvicorn|gunicorn)\\s+\\S+:\\S+",
      "message": "Never start app servers directly. Use 'st service rebuild <project>'.",
      "component_id": "sf.scripts"
    },
    {
      "pattern": "python[0-9.]*\\s+-m\\s+(uvicorn|gunicorn)\\b",
      "message": "Never start app servers directly. Use 'st service rebuild <project>'.",
      "component_id": "sf.scripts"
    },
    {
      "pattern": "(npm|pnpm)\\s+(run\\s+(dev|start)|start)\\b",
      "message": "Never start dev servers directly. Use 'st service rebuild <project>'.",
      "component_id": "sf.scripts"
    },
    {
      "pattern": "(npx\\s+)?next\\s+(dev|start)\\b",
      "message": "Never start dev servers directly. Use 'st service rebuild <project>'.",
      "component_id": "sf.scripts"
    },
    {
      "pattern": "psql\\b",
      "message": "Use 'st db' instead of raw psql. Commands: st db tables, st db schema <table>, st db sample <table> [n], st db query \"SELECT...\", st db migrate status.",
      "component_id": "sf.storage"
    },
    {
      "pattern": "\\brm\\s+(-[-A-Za-z]*[rR][-A-Za-z]*|--recursive)\\b|\\brmdir\\b|\\bfind\\b[^\\n]*\\s-delete\\b",
      "message": "Use 'st cleanup path <literal-path> [<literal-path>...] --recursive' for repo-local file or directory deletions. For task checkpoint cleanup, use 'st cleanup checkpoints --auto'. 'st cleanup path' validates repo root, blocks protected directories (.git, .st, node_modules), and supports --dry-run.",
      "component_id": "sf.cli"
    }
  ]
}
