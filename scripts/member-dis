#!/home/kasadis/summitflow/backend/.venv/bin/python3.13
"""member-dis: Agent-agnostic memory progressive disclosure CLI.

Zero baseline token cost. Works with any agent that can execute shell commands.
"""

from __future__ import annotations

import json
import os
import sys
from datetime import datetime
from pathlib import Path
from typing import Any

import httpx
import typer
from rich.console import Console
from rich.table import Table

__version__ = "0.1.0"

app = typer.Typer(
    name="member-dis",
    help="Memory progressive disclosure CLI. Search, expand, and browse project memory.",
    no_args_is_help=True,
)

console = Console()
err_console = Console(stderr=True)

# API Configuration
DEFAULT_API_BASE = "http://localhost:8001/api"


def get_api_base() -> str:
    """Get API base URL from environment."""
    return os.getenv("ST_API_BASE", DEFAULT_API_BASE)


def detect_project() -> str | None:
    """Auto-detect project ID from environment or cwd.

    Priority:
    1. ST_PROJECT_ID environment variable
    2. Walk up from cwd looking for .summitflow or CLAUDE.md
    3. Parse project name from directory path
    """
    # 1. Check environment variable
    if project := os.getenv("ST_PROJECT_ID"):
        return project

    # 2. Walk up looking for project markers
    cwd = Path.cwd()
    for parent in [cwd, *cwd.parents]:
        if (parent / ".summitflow").exists():
            return parent.name
        if (parent / "CLAUDE.md").exists():
            return parent.name

    # 3. Use current directory name as fallback
    return cwd.name


def get_project(project: str | None) -> str:
    """Get project ID, auto-detecting if not provided."""
    if project:
        return project

    detected = detect_project()
    if not detected:
        err_console.print(
            "[red]Error:[/red] Could not detect project. "
            "Use --project flag or run from project directory."
        )
        raise typer.Exit(1)

    return detected


def api_get(path: str, params: dict[str, Any] | None = None) -> dict[str, Any]:
    """Make GET request to API."""
    url = f"{get_api_base()}{path}"
    try:
        response = httpx.get(url, params=params, timeout=30.0)
        response.raise_for_status()
        return response.json()
    except httpx.HTTPStatusError as e:
        try:
            detail = e.response.json().get("detail", e.response.text)
        except Exception:
            detail = e.response.text
        err_console.print(f"[red]Error [{e.response.status_code}]:[/red] {detail}")
        raise typer.Exit(1) from e
    except httpx.RequestError as e:
        err_console.print(f"[red]Connection error:[/red] {e}")
        raise typer.Exit(1) from e


def api_post(path: str, data: dict[str, Any]) -> dict[str, Any]:
    """Make POST request to API."""
    url = f"{get_api_base()}{path}"
    try:
        response = httpx.post(url, json=data, timeout=30.0)
        response.raise_for_status()
        return response.json()
    except httpx.HTTPStatusError as e:
        try:
            detail = e.response.json().get("detail", e.response.text)
        except Exception:
            detail = e.response.text
        err_console.print(f"[red]Error [{e.response.status_code}]:[/red] {detail}")
        raise typer.Exit(1) from e
    except httpx.RequestError as e:
        err_console.print(f"[red]Connection error:[/red] {e}")
        raise typer.Exit(1) from e


def format_relative_time(timestamp: str | None) -> str:
    """Format timestamp as relative time."""
    if not timestamp:
        return ""

    try:
        # Parse ISO timestamp
        if timestamp.endswith("Z"):
            timestamp = timestamp[:-1] + "+00:00"
        dt = datetime.fromisoformat(timestamp)
        now = datetime.now(dt.tzinfo)

        delta = now - dt
        if delta.days == 0:
            hours = delta.seconds // 3600
            if hours == 0:
                mins = delta.seconds // 60
                return f"{mins}m ago" if mins > 0 else "now"
            return f"{hours}h ago"
        elif delta.days == 1:
            return "yesterday"
        elif delta.days < 7:
            return f"{delta.days}d ago"
        else:
            return dt.strftime("%b %d")
    except (ValueError, TypeError):
        return ""


# ============================================================================
# Commands
# ============================================================================


@app.command()
def search(
    query: str = typer.Argument(..., help="Search query"),
    project: str | None = typer.Option(None, "--project", "-p", help="Project ID"),
    type: str | None = typer.Option(
        None, "--type", "-t", help="Filter by type: observation, pattern, user_prompt"
    ),
    limit: int = typer.Option(10, "--limit", "-l", help="Max results"),
    use_json: bool = typer.Option(False, "--json", help="Output as JSON"),
) -> None:
    """Search project memory for observations, patterns, and prompts."""
    project_id = get_project(project)

    params = {
        "q": query,
        "project_id": project_id,
        "limit": limit,
    }
    if type:
        params["type"] = type

    result = api_get("/memory/search", params)

    if use_json:
        console.print(json.dumps(result, indent=2, default=str))
        return

    # Human-readable output
    results = result.get("results", [])
    total = result.get("total", len(results))

    if not results:
        console.print(f'No results for "{query}"')
        return

    console.print(f'Found {total} results for "{query}":\n')

    for i, item in enumerate(results, 1):
        entity_type = item.get("entity_type", "unknown")
        entity_id = item.get("id", "")
        title = item.get("title") or item.get("summary", "")[:60] or "No title"
        score = item.get("score", 0)
        created = format_relative_time(item.get("created_at"))

        # Format entity IDs: short for display, full for expand
        type_prefix = entity_type[:3]
        short_id = f"{type_prefix}:{entity_id[-8:]}" if entity_id else ""
        full_id = f"{type_prefix}:{entity_id}" if entity_id else ""

        console.print(f"{i}. [{short_id}] {title} ({score:.2f})")
        if created:
            console.print(f"   {created}")
        console.print(f"   [dim]→ member-dis expand {full_id}[/dim]")
        console.print()


@app.command()
def expand(
    entity_id: str = typer.Argument(
        ..., help="Entity ID to expand (e.g., obs:abc12345, pat:def67890)"
    ),
    project: str | None = typer.Option(None, "--project", "-p", help="Project ID"),
    use_json: bool = typer.Option(False, "--json", help="Output as JSON"),
) -> None:
    """Expand an entity to get full content."""
    project_id = get_project(project)

    result = api_post(f"/projects/{project_id}/context/expand", {"entity_id": entity_id})

    if use_json:
        console.print(json.dumps(result, indent=2, default=str))
        return

    # Human-readable output
    entity_type = result.get("type", "unknown")
    content = result.get("content", {})
    tokens = result.get("token_count", 0)

    console.print(f"[bold][{entity_id}][/bold] {content.get('title', 'No title')}\n")
    console.print(f"Type: {entity_type}")
    console.print(f"Tokens: ~{tokens}")

    if created := content.get("created_at"):
        console.print(f"Created: {format_relative_time(created)}")

    # Narrative/content
    if narrative := content.get("narrative"):
        console.print(f"\n[bold]Narrative:[/bold]\n{narrative}")
    elif pattern_content := content.get("content"):
        console.print(f"\n[bold]Content:[/bold]\n{pattern_content}")

    # Facts (for observations)
    if facts := content.get("facts"):
        console.print("\n[bold]Facts:[/bold]")
        if isinstance(facts, list):
            for fact in facts:
                console.print(f"  - {fact}")
        else:
            console.print(f"  {facts}")

    # Files
    if files := content.get("files_modified"):
        console.print(f"\n[bold]Files:[/bold] {', '.join(files)}")

    # Related entities
    if related := content.get("related"):
        console.print(f"\n[bold]Related:[/bold] {', '.join(related)}")


@app.command()
def index(
    project: str | None = typer.Option(None, "--project", "-p", help="Project ID"),
    limit: int = typer.Option(20, "--limit", "-l", help="Max items per category"),
    use_json: bool = typer.Option(False, "--json", help="Output as JSON"),
) -> None:
    """Show context index - compact overview of available memory."""
    project_id = get_project(project)

    result = api_get(f"/projects/{project_id}/context/index", {"limit": limit})

    if use_json:
        console.print(json.dumps(result, indent=2, default=str))
        return

    # Human-readable output
    items = result.get("items", [])
    item_count = result.get("item_count", len(items))
    index_tokens = result.get("index_tokens", 0)

    console.print(f"[bold]Context Index for {project_id}[/bold] ({item_count} items, ~{index_tokens} tokens)\n")

    # Group by type (API uses compact keys: t=type, tok=tokens)
    type_names = {"obs": "observation", "pat": "pattern", "cp": "checkpoint"}
    by_type: dict[str, list[dict[str, Any]]] = {}
    for item in items:
        t = item.get("t", "unknown")
        by_type.setdefault(t, []).append(item)

    for entity_type, type_items in by_type.items():
        type_label = type_names.get(entity_type, entity_type).upper() + "S"
        console.print(f"[bold]{type_label} ({len(type_items)}):[/bold]")

        for item in type_items[:10]:  # Show max 10 per type
            item_id = item.get("id", "")
            title = item.get("title") or item.get("summary", "")[:50] or "No title"
            tokens = item.get("tok", 0)
            age = format_relative_time(item.get("created_at"))

            # Truncate title if needed
            if len(title) > 50:
                title = title[:47] + "..."

            console.print(f"  {item_id:<45} {title:<45} ~{tokens:>4}t  {age}")

        if len(type_items) > 10:
            console.print(f"  ... {len(type_items) - 10} more")
        console.print()

    console.print("[dim]Use `member-dis expand <id>` for full content.[/dim]")


@app.command()
def timeline(
    anchor: str = typer.Option(..., "--anchor", "-a", help="Observation ID to center on"),
    before: int = typer.Option(5, "--before", "-b", help="Items before anchor"),
    after: int = typer.Option(5, "--after", "-A", help="Items after anchor"),
    project: str | None = typer.Option(None, "--project", "-p", help="Project ID"),
    use_json: bool = typer.Option(False, "--json", help="Output as JSON"),
) -> None:
    """Show timeline of observations around an anchor point."""
    project_id = get_project(project)

    params = {
        "anchor_id": anchor,
        "before": before,
        "after": after,
    }

    result = api_get(f"/projects/{project_id}/context/timeline", params)

    if use_json:
        console.print(json.dumps(result, indent=2, default=str))
        return

    # Human-readable output
    anchor_obs = result.get("anchor", {})
    before_obs = result.get("before", [])
    after_obs = result.get("after", [])
    total_tokens = result.get("total_tokens", 0)

    console.print(f"[bold]Timeline around {anchor}[/bold] (~{total_tokens} tokens)\n")

    def print_obs(obs: dict[str, Any], marker: str = " ") -> None:
        obs_id = obs.get("id", "")[-8:]
        title = obs.get("title", "No title")[:60]
        obs_type = obs.get("observation_type", "")
        created = format_relative_time(obs.get("created_at"))

        if marker == "→":
            console.print(f"[bold yellow]{marker} obs:{obs_id}  [{obs_type}] {title}  {created}[/bold yellow]")
        else:
            console.print(f"{marker} obs:{obs_id}  [{obs_type}] {title}  {created}")

    # Before (reverse to show oldest first)
    for obs in reversed(before_obs):
        print_obs(obs, "↑")

    # Anchor (highlighted)
    print_obs(anchor_obs, "→")

    # After
    for obs in after_obs:
        print_obs(obs, "↓")


def version_callback(value: bool) -> None:
    """Print version and exit."""
    if value:
        console.print(f"member-dis {__version__}")
        raise typer.Exit()


@app.callback()
def main(
    ctx: typer.Context,
    version: bool = typer.Option(
        False, "--version", "-V", callback=version_callback, is_eager=True,
        help="Show version and exit",
    ),
) -> None:
    """Memory progressive disclosure CLI.

    Search and retrieve project memory (observations, patterns, decisions).
    Zero baseline token cost - only pays for what you retrieve.
    """
    pass


if __name__ == "__main__":
    app()
