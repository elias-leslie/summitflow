# SummitFlow reads settings from ~/.env.local by default.
# Use these values as placeholders in ~/.env.local or export them in your shell.

# Required
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/summitflow

# Optional local test database
TEST_DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/summitflow_test

# Services
REDIS_URL=redis://localhost:6379
AGENT_HUB_URL=http://localhost:8003
AGENT_HUB_API_KEY=

# Agent Hub client identity
SUMMITFLOW_CLIENT_ID=YOUR_CLIENT_ID
SUMMITFLOW_CLIENT_SECRET=YOUR_CLIENT_SECRET
SUMMITFLOW_REQUEST_SOURCE=summitflow

# Hatchet
HATCHET_CLIENT_TOKEN=

# Web push
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@summitflow.dev

# Frontend and proxy integration
SUMMITFLOW_FRONTEND_URL=https://dev.summitflow.dev
NEXT_PUBLIC_VOICE_URL=

# CORS origins must be a shell-safe JSON string
CORS_ORIGINS='["http://localhost:3001","http://localhost:3002","http://localhost:3003","http://localhost:4001","https://dev.summitflow.dev","https://a-term.summitflow.dev","https://agent.summitflow.dev","https://mf.summitflow.dev"]'

# Backup SMB target (optional — only needed for remote backups)
SMB_HOST=nas.local
SMB_SHARE=backups
SMB_USER=backup-svc

# CLI / local overrides
ST_API_BASE=http://localhost:8001/api
