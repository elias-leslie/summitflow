# Copy to .env.local for native development or export these variables in your shell.
# Values below are placeholders; replace passwords/secrets before running shared services.

# Required native services
DATABASE_URL=postgresql://summitflow_app:CHANGE_ME@localhost:5432/summitflow
TEST_DATABASE_URL=postgresql://summitflow_app:CHANGE_ME@localhost:5432/summitflow_test
REDIS_URL=redis://localhost:6379/1

# Optional Agent Hub companion integration
AGENT_HUB_URL=http://localhost:8003
AGENT_HUB_API_KEY=
SUMMITFLOW_CLIENT_ID=summitflow
SUMMITFLOW_CLIENT_SECRET=
SUMMITFLOW_REQUEST_SOURCE=summitflow

# Hatchet workflow engine
HATCHET_CLIENT_TOKEN=
HATCHET_CLIENT_HOST_PORT=127.0.0.1:7070
HATCHET_CLIENT_TLS_STRATEGY=none

# Web push (optional)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# Frontend and CORS
SUMMITFLOW_FRONTEND_URL=http://localhost:3001
NEXT_PUBLIC_VOICE_URL=
CORS_ORIGINS=["http://localhost:3001","http://localhost:3003"]

# Durable Design Ops storage. Never point this at /tmp; the app refuses it.
SUMMITFLOW_MOCKUP_BASE_DIR=./data/design-studio/mockups

# Backup SMB target (optional)
SMB_HOST=
SMB_SHARE=
SMB_USER=

# CLI/local overrides
ST_API_BASE=http://localhost:8001/api
