{
  "manifest_version": 3,
  "name": "SummitFlow Co-Browser",
  "description": "Dedicated-profile Design Review overlay and page-state bridge.",
  "version": "0.1.0",
  "minimum_chrome_version": "120",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": [
    "http://127.0.0.1/*",
    "http://localhost/*",
    "http://192.168.8.244/*",
    "https://terminal.summitflow.dev/*",
    "https://terminalapi.summitflow.dev/*"
  ],
  "background": {
    "service_worker": "dist/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "http://127.0.0.1/*",
        "http://localhost/*",
        "http://192.168.8.244/*",
        "https://terminal.summitflow.dev/*"
      ],
      "js": ["dist/pairingBridge.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_title": "SummitFlow Co-Browser"
  },
  "web_accessible_resources": [
    {
      "resources": ["dist/content.js"],
      "matches": ["http://*/*", "https://*/*"]
    }
  ]
}
